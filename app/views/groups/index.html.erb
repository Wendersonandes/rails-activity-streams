<% if turbo_frame_request? && @pagy.page > 1 %>
  <%= turbo_frame_tag "groups_page_#{@pagy.page}", class: "space-y-4 block" do %>
    <%= render partial: "groups/group_card", collection: @groups, as: :group_actor %>
    <% if @pagy.next %>
      <%= turbo_frame_tag "groups_page_#{@pagy.next}", src: groups_path(page: @pagy.next), loading: :lazy, class: "space-y-4 block" do %>
        <div class="flex justify-center items-center py-6 gap-2 text-gray-500">
          <div class="animate-spin rounded-full h-5 w-5 border-2 border-gray-300 border-t-blue-600"></div>
          <span class="text-sm font-medium">Loading more groups...</span>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% else %>
  <%= content_for :title, "Groups" %>

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Groups</h1>
      <p class="text-xs text-gray-500 mt-0.5">Explore or join organization communities</p>
    </div>
    <% if current_actor %>
      <%= link_to new_group_path, class: "inline-flex items-center gap-1.5 text-xs bg-blue-600 hover:bg-blue-700 text-white font-medium px-3.5 py-2 rounded-lg transition-colors shadow-sm" do %>
        <i data-lucide="plus" class="w-4 h-4"></i>
        <span>New Group</span>
      <% end %>
    <% end %>
  </div>

  <% if @groups.any? %>
    <div class="space-y-4 mt-6">
      <%= render partial: "groups/group_card", collection: @groups, as: :group_actor %>
      <% if @pagy.next %>
        <%= turbo_frame_tag "groups_page_#{@pagy.next}", src: groups_path(page: @pagy.next), loading: :lazy, class: "space-y-4 block" do %>
          <div class="flex justify-center items-center py-6 gap-2 text-gray-500">
            <div class="animate-spin rounded-full h-5 w-5 border-2 border-gray-300 border-t-blue-600"></div>
            <span class="text-sm font-medium">Loading more groups...</span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center text-gray-500 py-16 bg-white rounded-xl border border-gray-200/80 p-8 shadow-sm">
      <div class="w-12 h-12 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3 border border-gray-100">
        <i data-lucide="layers" class="w-6 h-6 text-gray-400"></i>
      </div>
      <h3 class="text-base font-semibold text-gray-900">No groups yet</h3>
      <p class="text-sm text-gray-500 mt-1 max-w-sm mx-auto">Be the first to start a group in this organization!</p>
    </div>
  <% end %>
<% end %>

<% content_for :right_sidebar do %>
  <div class="bg-white rounded-xl border border-gray-200/80 p-5 shadow-sm sticky top-20 space-y-4">
    <div>
      <h3 class="text-sm font-semibold text-gray-900 flex items-center gap-1.5">
        <i data-lucide="sparkles" class="w-4 h-4 text-blue-600"></i>
        <span>Suggestions</span>
      </h3>
      <p class="text-xs text-gray-500 mt-0.5">People you might want to connect with</p>
    </div>

    <% if current_actor %>
      <%= turbo_frame_tag "sidebar_suggestions",
                          data: {
                            controller: "turbo-frame-reload",
                            action: "contact:changed@window->turbo-frame-reload#reload",
                            turbo_frame_reload_url_value: suggestions_path
                          } do %>
        <%= render "shared/sidebar_suggestions" %>
      <% end %>
    <% end %>
  </div>
<% end %>
