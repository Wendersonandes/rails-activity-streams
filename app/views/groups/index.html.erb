<%= content_for :title, "Groups" %>

<div class="max-w-2xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Groups</h1>
      <p class="text-xs text-gray-500 mt-0.5">Explore or join organization communities</p>
    </div>
    <% if current_actor %>
      <%= link_to new_group_path, class: "inline-flex items-center gap-1.5 text-xs bg-blue-600 hover:bg-blue-700 text-white font-medium px-3.5 py-2 rounded-lg transition-colors shadow-sm" do %>
        <i data-lucide="plus" class="w-4 h-4"></i>
        <span>New Group</span>
      <% end %>
    <% end %>
  </div>

  <% if @groups.any? %>
    <div class="space-y-4">
      <% @groups.each do |group_actor| %>
        <% group = group_actor.subject %>
        <div class="bg-white rounded-xl border border-gray-200/80 p-5 shadow-sm flex items-center justify-between hover:border-gray-300 transition-all duration-200 gap-4">
          <div class="flex items-center gap-4 min-w-0">
            <!-- Group Avatar -->
            <% if group_actor.avatar.attached? %>
              <%= image_tag group_actor.avatar.variant(:thumb), class: "w-12 h-12 rounded-lg object-cover border border-gray-100 flex-shrink-0" %>
            <% else %>
              <div class="w-12 h-12 rounded-lg bg-emerald-50 text-emerald-600 border border-emerald-100 flex items-center justify-center font-bold text-lg flex-shrink-0">
                <%= group_actor.name.first.upcase %>
              </div>
            <% end %>

            <div class="min-w-0 space-y-0.5">
              <div class="flex items-center gap-2">
                <h3 class="font-semibold text-gray-900 text-base truncate leading-snug">
                  <%= link_to group_actor.name, group_path(group), class: "hover:text-blue-600 transition-colors" %>
                </h3>
                <span class="text-[10px] font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 <%= group.public_group? ? 'bg-green-50 text-green-700 border border-green-100' : 'bg-yellow-50 text-yellow-700 border border-yellow-100' %>">
                  <i data-lucide="<%= group.public_group? ? 'globe' : 'lock' %>" class="w-2.5 h-2.5"></i>
                  <span><%= group.public_group? ? "Public" : "Private" %></span>
                </span>
              </div>
              <% if group_actor.description.present? %>
                <p class="text-sm text-gray-500 truncate max-w-md"><%= group_actor.description %></p>
              <% end %>
              <p class="text-xs text-gray-400 font-medium flex items-center gap-1">
                <i data-lucide="users" class="w-3.5 h-3.5"></i>
                <span><%= group_actor.sent_contacts.active.count %> members</span>
              </p>
            </div>
          </div>
          
          <div class="flex-shrink-0">
            <% if current_actor && current_actor != group_actor %>
              <% if group_actor.member_roles_for(current_actor).any? %>
                <span class="text-xs font-semibold text-emerald-700 bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-md">Member</span>
              <% else %>
                <% if group.public_group? %>
                  <%= button_to group_memberships_path(group), params: { actor_id: current_actor.id, role: "member" }, method: :post, class: "inline-flex items-center gap-1 text-xs bg-blue-600 hover:bg-blue-700 text-white font-medium px-3.5 py-1.8 rounded-lg transition-colors cursor-pointer border-0 shadow-sm" do %>
                    <i data-lucide="plus" class="w-3.5 h-3.5"></i>
                    <span>Join</span>
                  <% end %>
                <% else %>
                  <%= button_to group_memberships_path(group), params: { actor_id: current_actor.id }, method: :post, class: "inline-flex items-center gap-1 text-xs bg-gray-50 hover:bg-gray-100 text-gray-700 font-medium px-3.5 py-1.8 rounded-lg border border-gray-200 transition-colors cursor-pointer" do %>
                    <i data-lucide="lock" class="w-3.5 h-3.5"></i>
                    <span>Request</span>
                  <% end %>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center text-gray-500 py-16 bg-white rounded-xl border border-gray-200/80 p-8 shadow-sm">
      <div class="w-12 h-12 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3 border border-gray-100">
        <i data-lucide="layers" class="w-6 h-6 text-gray-400"></i>
      </div>
      <h3 class="text-base font-semibold text-gray-900">No groups yet</h3>
      <p class="text-sm text-gray-500 mt-1 max-w-sm mx-auto">Be the first to start a group in this organization!</p>
    </div>
  <% end %>

  <% if @pagy.pages > 1 %>
    <div class="mt-6 flex justify-center"><%== pagy_nav(@pagy) %></div>
  <% end %>
</div>
