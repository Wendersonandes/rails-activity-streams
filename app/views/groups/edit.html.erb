<%= content_for :title, "Edit #{@group.name}" %>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Edit Group</h1>

  <%= form_with model: @group, class: "bg-white rounded-lg shadow p-6 border border-gray-100" do |f| %>
    <div class="mb-4">
      <%= f.label :privacy, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :privacy, [["Public", "public_group"], ["Private", "private_group"]], {}, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <%= f.fields_for :actor do |af| %>
      <div class="mb-4">
        <%= af.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= af.text_field :name, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= af.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= af.text_area :description, rows: 3, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= af.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= af.email_field :email, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="mb-4">
        <%= af.label :avatar, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <% if @group.actor.avatar.attached? %>
          <div class="mb-2"><%= image_tag @group.actor.avatar.variant(:thumb), class: "w-20 h-20 rounded-lg object-cover border" %></div>
        <% end %>
        <%= af.file_field :avatar, accept: "image/png,image/jpeg,image/webp", class: "w-full text-sm text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
      </div>

      <div class="mb-4">
        <%= af.label :cover_image, "Cover Image", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <% if @group.actor.cover_image.attached? %>
          <div class="mb-2"><%= image_tag @group.actor.cover_image.variant(:thumb), class: "w-full max-w-md h-24 object-cover rounded-lg border" %></div>
        <% end %>
        <%= af.file_field :cover_image, accept: "image/png,image/jpeg,image/webp", class: "w-full text-sm text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
      </div>
    <% end %>

    <div class="flex items-center justify-between">
      <%= f.submit "Save", class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancel", group_path(@group), class: "text-sm text-gray-500 hover:text-gray-700" %>
    </div>
  <% end %>
</div>
