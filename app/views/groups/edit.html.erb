<%= content_for :title, "Edit #{@group.name}" %>

<div class="max-w-lg mx-auto space-y-6">
  <div class="flex items-center gap-2">
    <%= link_to group_path(@group), class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
      <i data-lucide="arrow-left" class="w-5 h-5"></i>
    <% end %>
    <span class="text-sm font-medium text-gray-500">Back to Group</span>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Edit Group Settings</h1>

  <%= form_with model: @group, class: "bg-white rounded-xl border border-gray-200/80 p-6 shadow-sm space-y-5" do |f| %>
    <div class="space-y-1">
      <%= f.label :privacy, "Privacy Level", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :privacy, [["Public Group (anyone can join)", "public_group"], ["Private Group (requires approval)", "private_group"]], {}, 
            class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow" %>
    </div>

    <%= f.fields_for :actor do |af| %>
      <div class="space-y-1">
        <%= af.label :name, class: "block text-sm font-medium text-gray-700" %>
        <%= af.text_field :name, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow" %>
      </div>

      <div class="space-y-1">
        <%= af.label :description, class: "block text-sm font-medium text-gray-700" %>
        <%= af.text_area :description, rows: 3, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow" %>
      </div>

      <div class="space-y-1">
        <%= af.label :email, class: "block text-sm font-medium text-gray-700" %>
        <%= af.email_field :email, class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
        <!-- Avatar Upload -->
        <div class="space-y-2">
          <%= af.label :avatar, "Group Avatar", class: "block text-sm font-medium text-gray-700" %>
          <div class="flex items-center gap-3">
            <% if @group.actor.avatar.attached? %>
              <%= image_tag @group.actor.avatar.variant(:thumb), class: "w-12 h-12 rounded-lg object-cover border border-gray-200" %>
            <% else %>
              <div class="w-12 h-12 rounded-lg bg-emerald-50 text-emerald-600 border border-emerald-100 flex items-center justify-center font-bold text-lg">
                <%= @group.name.first.upcase %>
              </div>
            <% end %>
            <div class="flex-1 min-w-0">
              <%= af.file_field :avatar, accept: "image/png,image/jpeg,image/webp", class: "w-full text-xs text-gray-500 file:mr-2 file:py-1 file:px-2.5 file:rounded-md file:border file:border-gray-200 file:text-xs file:font-semibold file:bg-gray-50 file:text-gray-700 hover:file:bg-gray-100 cursor-pointer" %>
            </div>
          </div>
        </div>

        <!-- Cover Image Upload -->
        <div class="space-y-2">
          <%= af.label :cover_image, "Cover Image", class: "block text-sm font-medium text-gray-700" %>
          <div class="flex items-center gap-3">
            <% if @group.actor.cover_image.attached? %>
              <%= image_tag @group.actor.cover_image.variant(:thumb), class: "w-12 h-8 rounded object-cover border border-gray-200" %>
            <% else %>
              <div class="w-12 h-8 rounded bg-gray-50 border border-gray-200 flex items-center justify-center text-gray-300">
                <i data-lucide="image" class="w-4 h-4"></i>
              </div>
            <% end %>
            <div class="flex-1 min-w-0">
              <%= af.file_field :cover_image, accept: "image/png,image/jpeg,image/webp", class: "w-full text-xs text-gray-500 file:mr-2 file:py-1 file:px-2.5 file:rounded-md file:border file:border-gray-200 file:text-xs file:font-semibold file:bg-gray-50 file:text-gray-700 hover:file:bg-gray-100 cursor-pointer" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div class="flex items-center justify-between border-t border-gray-100 pt-5 mt-2">
      <%= link_to "Cancel", group_path(@group), class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" %>
      <%= f.submit "Save changes", class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all shadow-sm cursor-pointer" %>
    </div>
  <% end %>
</div>
