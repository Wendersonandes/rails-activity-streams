<%= content_for :title, @group.name %>

<%
  can_see_content = @group.public_group? || @is_member
  container_class = @is_member ? "max-w-6xl" : "max-w-2xl"
%>

<div class="<%= container_class %> mx-auto">
  <div class="flex flex-col lg:flex-row gap-6">
    <div class="flex-1 min-w-0 space-y-6">
      <div class="bg-white rounded-xl border border-gray-200/80 shadow-sm overflow-hidden">
        <% if @group.actor.cover_image.attached? %>
          <%= image_tag @group.actor.cover_image.variant(:thumb), class: "w-full h-44 object-cover" %>
        <% else %>
          <div class="w-full h-32 bg-gray-50 border-b border-gray-200/60 flex items-center justify-center text-gray-300">
            <i data-lucide="image" class="w-8 h-8"></i>
          </div>
        <% end %>
        <div class="p-6 -mt-10 sm:-mt-12 relative">
          <div class="flex items-start gap-4">
            <div class="w-20 h-20 bg-white rounded-xl p-1 shadow flex-shrink-0 border border-gray-100 overflow-hidden">
              <% if @group.actor.avatar.attached? %>
                <%= image_tag @group.actor.avatar.variant(:thumb), class: "w-full h-full rounded-lg object-cover" %>
              <% else %>
                <div class="w-full h-full rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center font-bold text-2xl border border-emerald-100">
                  <%= @group.name.first.upcase %>
                </div>
              <% end %>
            </div>
            
            <div class="flex-1 min-w-0 pt-10 sm:pt-12">
              <div class="flex flex-wrap items-center gap-2">
                <h1 class="text-2xl font-bold text-gray-900 tracking-tight truncate"><%= @group.name %></h1>
                <span class="text-[10px] font-medium px-2 py-0.5 rounded-full inline-flex items-center gap-1 <%= @group.public_group? ? 'bg-green-50 text-green-700 border border-green-100' : 'bg-yellow-50 text-yellow-700 border border-yellow-100' %>">
                  <i data-lucide="<%= @group.public_group? ? 'globe' : 'lock' %>" class="w-2.5 h-2.5"></i>
                  <span><%= @group.public_group? ? "Public" : "Private" %></span>
                </span>
              </div>
              
              <% if @group.description.present? %>
                <p class="text-sm text-gray-600 mt-2 leading-relaxed"><%= @group.description %></p>
              <% end %>
              
              <div class="flex gap-4 mt-3 text-xs text-gray-400 font-medium">
                <span class="flex items-center gap-1"><i data-lucide="file-text" class="w-3.5 h-3.5"></i> <%= @group.actor.authored_activities.count %> posts</span>
                <span class="flex items-center gap-1"><i data-lucide="users" class="w-3.5 h-3.5"></i> <%= @group.actor.sent_contacts.active.count %> members</span>
              </div>

              <% if current_actor == @group.actor || (@is_member && @group.actor.has_relation_with?(current_actor, "Admin")) %>
                <div class="mt-4 flex items-center gap-3 pt-3 border-t border-gray-100">
                  <%= link_to edit_group_path(@group), class: "inline-flex items-center gap-1 text-xs bg-gray-50 hover:bg-gray-100 text-gray-700 font-medium px-3 py-1.5 rounded-lg border border-gray-200 transition-colors" do %>
                    <i data-lucide="settings" class="w-3.5 h-3.5"></i>
                    <span>Edit Group</span>
                  <% end %>
                  <% if current_actor == @group.actor %>
                    <%= button_to group_path(@group), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this group?" }, class: "inline-flex items-center gap-1 text-xs bg-red-50 hover:bg-red-100 text-red-600 hover:text-red-700 border border-red-100 px-3 py-1.5 rounded-lg font-medium transition-colors cursor-pointer" do %>
                      <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                      <span>Delete</span>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <% if can_see_content %>
        <div class="flex border-b border-gray-200/80 mb-4 bg-white/50 p-1 rounded-lg border border-gray-100/50">
          <%= link_to group_path(@group), class: "flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-md transition-all #{request.path == group_path(@group) ? 'bg-white text-blue-600 shadow-sm border border-gray-150' : 'text-gray-500 hover:text-gray-900'}" do %>
            <i data-lucide="message-square" class="w-4 h-4"></i>
            <span>Posts</span>
          <% end %>
          <%= link_to group_memberships_path(@group), class: "flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-md transition-all #{request.path.start_with?(group_memberships_path(@group)) && !request.path.include?("/insights") ? 'bg-white text-blue-600 shadow-sm border border-gray-150' : 'text-gray-500 hover:text-gray-900'}" do %>
            <i data-lucide="users" class="w-4 h-4"></i>
            <span>Members (<%= @group.actor.sent_contacts.active.count %>)</span>
          <% end %>
          <% if @is_member && @group.actor.has_relation_with?(current_actor, "Admin") %>
            <%= link_to insights_group_memberships_path(@group), class: "flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-md transition-all #{request.path.include?("/insights") ? 'bg-white text-blue-600 shadow-sm border border-gray-150' : 'text-gray-500 hover:text-gray-900'}" do %>
              <i data-lucide="bar-chart-3" class="w-4 h-4"></i>
              <span>Insights</span>
            <% end %>
          <% end %>
        </div>

        <div class="space-y-4">
          <% if @activities.any? %>
            <%= render partial: "shared/activity", collection: @activities, as: :activity %>
          <% else %>
            <div class="text-center text-gray-500 py-16 bg-white rounded-xl border border-gray-200/80 p-8 shadow-sm">
              <div class="w-12 h-12 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3 border border-gray-100">
                <i data-lucide="file-text" class="w-6 h-6 text-gray-400"></i>
              </div>
              <h3 class="text-base font-semibold text-gray-900">No posts yet</h3>
              <p class="text-sm text-gray-500 mt-1 max-w-sm mx-auto">No one has shared anything in this group yet.</p>
            </div>
          <% end %>
        </div>

        <% if @pagy.pages > 1 %>
          <div class="mt-6 flex justify-center"><%== pagy_nav(@pagy) %></div>
        <% end %>
      <% else %>
        <div class="text-center py-16 bg-white rounded-xl border border-gray-200/80 p-8 shadow-sm">
          <div class="w-12 h-12 bg-yellow-50 rounded-full flex items-center justify-center mx-auto mb-4 border border-yellow-100">
            <i data-lucide="lock" class="w-6 h-6 text-yellow-600"></i>
          </div>
          <h2 class="text-base font-bold text-gray-900">Private Group</h2>
          <p class="text-sm text-gray-500 mt-1 max-w-xs mx-auto mb-6">This community is private. Request to join below to view its posts and members list.</p>
          <%= button_to group_memberships_path(@group), params: { actor_id: current_actor&.id }, method: :post, class: "inline-flex items-center gap-1.5 text-sm bg-blue-600 hover:bg-blue-700 text-white font-medium px-4 py-2 rounded-lg transition-all shadow-sm cursor-pointer border-0" do %>
            <i data-lucide="user-plus" class="w-4 h-4"></i>
            <span>Request to Join Group</span>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @is_member %>
      <aside class="w-full lg:w-72 flex-shrink-0">
        <div class="bg-white rounded-xl border border-gray-200/80 p-5 shadow-sm sticky top-20 space-y-4">
          <h3 class="text-sm font-semibold text-gray-900 flex items-center justify-between pb-2 border-b border-gray-100">
            <span>Members</span>
            <span class="text-gray-400 font-normal text-xs">(<%= @admins.size + @moderators.size + @members.size %>)</span>
          </h3>

          <% if @admins.any? %>
            <div class="space-y-1.5">
              <span class="text-[10px] uppercase font-bold tracking-wider text-gray-400 block px-2">Admins</span>
              <% @admins.each do |actor| %>
                <%= link_to public_path_for(actor), class: "flex items-center gap-2 py-1.5 px-2 rounded-lg hover:bg-gray-50 transition-colors" do %>
                  <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 overflow-hidden">
                    <% if actor.avatar.attached? %>
                      <%= image_tag actor.avatar.variant(:thumb), class: "w-7 h-7 rounded-full object-cover" %>
                    <% else %>
                      <span class="bg-blue-50 w-full h-full flex items-center justify-center text-blue-600 border border-blue-100"><%= actor.name[0].upcase %></span>
                    <% end %>
                  </div>
                  <span class="flex-1 text-sm text-gray-900 truncate font-medium"><%= actor.name %></span>
                  <span class="text-[10px] bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded font-semibold border border-blue-100/50 flex-shrink-0">Admin</span>
                <% end %>
              <% end %>
            </div>
          <% end %>

          <% if @moderators.any? %>
            <div class="space-y-1.5">
              <span class="text-[10px] uppercase font-bold tracking-wider text-gray-400 block px-2">Moderators</span>
              <% @moderators.each do |actor| %>
                <%= link_to public_path_for(actor), class: "flex items-center gap-2 py-1.5 px-2 rounded-lg hover:bg-gray-50 transition-colors" do %>
                  <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 overflow-hidden">
                    <% if actor.avatar.attached? %>
                      <%= image_tag actor.avatar.variant(:thumb), class: "w-7 h-7 rounded-full object-cover" %>
                    <% else %>
                      <span class="bg-emerald-50 w-full h-full flex items-center justify-center text-emerald-600 border border-emerald-100"><%= actor.name[0].upcase %></span>
                    <% end %>
                  </div>
                  <span class="flex-1 text-sm text-gray-900 truncate font-medium"><%= actor.name %></span>
                  <span class="text-[10px] bg-emerald-50 text-emerald-700 px-1.5 py-0.5 rounded font-semibold border border-emerald-100/50 flex-shrink-0">Mod</span>
                <% end %>
              <% end %>
            </div>
          <% end %>

          <% if @members.any? %>
            <div class="space-y-1.5">
              <span class="text-[10px] uppercase font-bold tracking-wider text-gray-400 block px-2">Members</span>
              <% @members.first(12).each do |actor| %>
                <%= link_to public_path_for(actor), class: "flex items-center gap-2 py-1.5 px-2 rounded-lg hover:bg-gray-50 transition-colors" do %>
                  <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 overflow-hidden">
                    <% if actor.avatar.attached? %>
                      <%= image_tag actor.avatar.variant(:thumb), class: "w-7 h-7 rounded-full object-cover" %>
                    <% else %>
                      <span class="bg-gray-55 w-full h-full flex items-center justify-center text-gray-500 border border-gray-200"><%= actor.name[0].upcase %></span>
                    <% end %>
                  </div>
                  <span class="flex-1 text-sm text-gray-900 truncate"><%= actor.name %></span>
                <% end %>
              <% end %>
              <% if @members.size > 12 %>
                <p class="text-[10px] text-gray-400 px-2 pt-1 font-medium">+<%= @members.size - 12 %> more members</p>
              <% end %>
            </div>
          <% end %>

          <%= link_to group_memberships_path(@group), class: "flex items-center justify-center gap-1.5 text-xs text-blue-600 hover:text-blue-700 font-semibold mt-3 pt-3 border-t border-gray-100 transition-colors" do %>
            <span>View all members</span>
            <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
          <% end %>
        </div>
      </aside>
    <% end %>
  </div>
</div>
