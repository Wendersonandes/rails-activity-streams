<%
  member_roles = current_actor ? @group.actor.member_roles_for(current_actor) : []
  is_member = member_roles.any?
  is_admin = current_actor && @group.actor.has_relation_with?(current_actor, "Admin")
  total_members = @group.actor.sent_contacts.active.count
%>

<div class="flex items-center justify-between border-b border-gray-200/80 mb-4 bg-white/50 p-1 rounded-lg border border-gray-100/50">
  <div class="flex gap-1">
    <%= link_to group_path(@group), class: "flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-md transition-all #{request.path == group_path(@group) ? 'bg-white text-blue-600 shadow-sm border border-gray-200' : 'text-gray-500 hover:text-gray-900'}" do %>
      <i data-lucide="message-square" class="w-4 h-4"></i>
      <span>Posts</span>
    <% end %>
    
    <%= link_to group_memberships_path(@group), class: "flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-md transition-all #{request.path.start_with?(group_memberships_path(@group)) && !request.path.include?('/insights') ? 'bg-white text-blue-600 shadow-sm border border-gray-200' : 'text-gray-500 hover:text-gray-900'}" do %>
      <i data-lucide="users" class="w-4 h-4"></i>
      <span>Members (<%= total_members %>)</span>
    <% end %>
    
    <% if is_admin %>
      <%= link_to insights_group_memberships_path(@group), class: "flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-md transition-all #{request.path.include?('/insights') ? 'bg-white text-blue-600 shadow-sm border border-gray-200' : 'text-gray-500 hover:text-gray-900'}" do %>
        <i data-lucide="bar-chart-3" class="w-4 h-4"></i>
        <span>Insights</span>
      <% end %>
    <% end %>
  </div>

  <% if current_actor %>
    <div class="pr-2 flex items-center">
      <% if is_member %>
        <%= button_to group_membership_path(@group, current_actor, role: member_roles.first), method: :delete, data: { turbo_confirm: "Are you sure you want to leave #{@group.name}?" }, class: "flex items-center gap-1.5 text-xs bg-red-50 text-red-700 hover:bg-red-100 border border-red-200 px-3 py-1.5 rounded-lg font-medium transition-colors cursor-pointer" do %>
          <i data-lucide="log-out" class="w-3.5 h-3.5"></i>
          <span>Leave Group</span>
        <% end %>
      <% else %>
        <% if @group.public_group? %>
          <%= button_to group_memberships_path(@group), params: { actor_id: current_actor.id, role: "member" }, method: :post, class: "flex items-center gap-1.5 text-xs bg-blue-50 text-blue-700 hover:bg-blue-100 border border-blue-200 px-3 py-1.5 rounded-lg font-medium transition-colors cursor-pointer" do %>
            <i data-lucide="plus" class="w-3.5 h-3.5"></i>
            <span>Join Group</span>
          <% end %>
        <% else %>
          <% if current_actor.contact_to(@group.actor).present? %>
            <span class="flex items-center gap-1.5 text-xs bg-yellow-50 text-yellow-700 border border-yellow-200 px-3 py-1.5 rounded-lg font-medium transition-colors">
              <i data-lucide="clock" class="w-3.5 h-3.5"></i>
              <span>Request Pending</span>
            </span>
          <% else %>
            <%= button_to group_memberships_path(@group), params: { actor_id: current_actor.id }, method: :post, class: "flex items-center gap-1.5 text-xs bg-blue-50 text-blue-700 hover:bg-blue-100 border border-blue-200 px-3 py-1.5 rounded-lg font-medium transition-colors cursor-pointer" do %>
              <i data-lucide="lock" class="w-3.5 h-3.5"></i>
              <span>Request to Join</span>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
