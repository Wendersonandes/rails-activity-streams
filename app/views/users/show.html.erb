<%= content_for :title, "Account" %>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Account Settings</h1>

  <div class="bg-white rounded-lg shadow border border-gray-100 divide-y">
    <div class="p-4 flex items-center justify-between">
      <div>
        <h3 class="font-medium text-gray-900">Email</h3>
        <p class="text-sm text-gray-500"><%= current_user.email %></p>
      </div>
      <%= link_to "Edit", edit_account_path, class: "text-sm text-blue-600 hover:underline" %>
    </div>

    <% if current_actor %>
      <div class="p-4 flex items-center justify-between">
        <div>
          <h3 class="font-medium text-gray-900">Profile</h3>
          <p class="text-sm text-gray-500"><%= current_actor.name %></p>
        </div>
        <div class="flex items-center gap-3">
          <%= link_to "View", public_path_for(current_actor), class: "text-sm text-blue-600 hover:underline" %>
          <%= link_to "Edit", edit_my_profile_path, class: "text-sm text-blue-600 hover:underline" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
