<%= content_for :title, "Account Settings" %>

<div class="max-w-lg mx-auto space-y-6">
  <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Account Settings</h1>

  <div class="bg-white rounded-xl border border-gray-200/80 shadow-sm divide-y divide-gray-100 overflow-hidden">
    <!-- Email Setting -->
    <div class="p-5 flex items-center justify-between hover:bg-gray-50/50 transition-colors">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center text-gray-500 border border-gray-100">
          <i data-lucide="mail" class="w-5 h-5"></i>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-gray-900">Email Address</h3>
          <p class="text-sm text-gray-500 mt-0.5"><%= current_user.email %></p>
        </div>
      </div>
      <%= link_to edit_account_path, class: "flex items-center gap-1 text-xs bg-gray-150/50 text-gray-700 hover:bg-gray-200/60 font-medium px-3 py-1.5 rounded-md border border-gray-200 transition-colors" do %>
        <i data-lucide="edit-3" class="w-3.5 h-3.5"></i>
        <span>Edit</span>
      <% end %>
    </div>

    <!-- Profile Setting -->
    <% if current_actor %>
      <div class="p-5 flex items-center justify-between hover:bg-gray-50/50 transition-colors">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center text-gray-500 border border-gray-100">
            <i data-lucide="user" class="w-5 h-5"></i>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-gray-900">Public Profile</h3>
            <p class="text-sm text-gray-500 mt-0.5"><%= current_actor.name %></p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to public_path_for(current_actor), class: "flex items-center gap-1 text-xs bg-gray-150/50 text-gray-700 hover:bg-gray-200/60 font-medium px-3 py-1.5 rounded-md border border-gray-200 transition-colors" do %>
            <i data-lucide="eye" class="w-3.5 h-3.5"></i>
            <span>View</span>
          <% end %>
          <%= link_to edit_my_profile_path, class: "flex items-center gap-1 text-xs bg-gray-150/50 text-gray-700 hover:bg-gray-200/60 font-medium px-3 py-1.5 rounded-md border border-gray-200 transition-colors" do %>
            <i data-lucide="edit-3" class="w-3.5 h-3.5"></i>
            <span>Edit</span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
