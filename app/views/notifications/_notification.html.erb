<%= turbo_frame_tag dom_id(notification) do %>
  <% event = notification.event %>
  <% unread = notification.unread? %>
  <div class="flex items-start justify-between gap-4 p-4.5 transition-colors <%= unread ? 'bg-blue-50/30' : 'hover:bg-gray-50/50' %>">
    <div class="flex items-start gap-3.5 flex-1 min-w-0">
      <% trigger_activity = event.params[:activity] %>
      <% trigger_author = trigger_activity&.author %>
      
      <div class="flex-shrink-0">
        <% if trigger_author&.avatar&.attached? %>
          <%= image_tag trigger_author.avatar.variant(:thumb), class: "w-10 h-10 rounded-full object-cover border border-gray-100" %>
        <% else %>
          <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-650 font-bold border border-blue-100 text-sm">
            <%= (trigger_author&.name || "?").first.upcase %>
          </div>
        <% end %>
      </div>

      <div class="flex-1 min-w-0">
        <p class="text-sm text-gray-900 leading-snug">
          <%= link_to notification.message, notification.url, class: "hover:text-blue-650 hover:underline font-medium break-words", data: { turbo: false } %>
        </p>
        <span class="text-[11px] font-medium text-gray-500 mt-1 block">
          <%= time_ago_in_words(notification.created_at) %> ago
        </span>
      </div>
    </div>

    <% if unread %>
      <div class="flex items-center gap-2 self-center flex-shrink-0">
        <span class="w-2.5 h-2.5 rounded-full bg-blue-600"></span>
        <%= button_to notification_path(notification), method: :patch, class: "text-xs font-semibold text-gray-500 hover:text-blue-600 bg-transparent border-0 cursor-pointer p-1" do %>
          <i data-lucide="check" class="w-4 h-4"></i>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
