<%= content_for :title, "Feed" %>

<div class="grid grid-cols-12 gap-6">
  <div class="col-span-12 lg:col-span-8">
    <% if current_actor %>
      <div class="bg-white rounded-lg shadow p-4 mb-6 border border-gray-100">
        <%= link_to "New Post", new_activity_path, class: "block w-full text-left bg-gray-50 border border-gray-200 rounded-full px-4 py-2 text-gray-500 hover:bg-gray-100" %>
      </div>
    <% end %>

    <div id="feed">
      <% if @activities.any? %>
        <%= render partial: "shared/activity", collection: @activities, as: :activity %>
      <% else %>
        <div class="text-center text-gray-500 py-12">
          <p class="text-lg">No activities yet.</p>
          <p class="text-sm mt-2">Connect with others to see their posts here.</p>
        </div>
      <% end %>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="mt-6 flex justify-center">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  </div>

  <div class="hidden lg:block col-span-4">
    <div class="bg-white rounded-lg shadow p-4 border border-gray-100 sticky top-20">
      <h3 class="font-semibold text-gray-900 mb-2">Suggestions</h3>
      <% if current_actor %>
        <% current_actor.suggestions(3).each do |contact| %>
          <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
            <span class="text-sm font-medium text-gray-700"><%= contact.receiver.name %></span>
            <%= link_to "Connect", contacts_path(actor_id: contact.receiver.slug, as: :friend), data: { turbo_method: :post }, class: "text-xs text-blue-600 hover:underline" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
