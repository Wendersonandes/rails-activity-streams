<%
  title_value = local_assigns[:clear_inputs] ? "" : (activity.direct_object&.title || params.dig(:activity, :text, :title))
  body_value = local_assigns[:clear_inputs] ? "" : (activity.direct_object&.description || params.dig(:activity, :text, :body))
%>

<%= form_with model: activity, id: "activity_form_container", class: "bg-white rounded-xl border border-gray-200/80 p-6 shadow-sm space-y-5" do |f| %>
  <%= f.hidden_field :verb %>
  <%= f.hidden_field :owner_id %>

  <% if activity.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-lg text-sm space-y-1">
      <% activity.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="space-y-1">
    <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :title, name: "activity[text][title]", value: title_value, placeholder: "Title of your post (optional)",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow" %>
  </div>

  <div class="space-y-1">
    <%= f.label :body, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :body, name: "activity[text][body]", value: body_value, rows: 5, placeholder: "What would you like to share?",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow" %>
  </div>

  <div class="flex items-center justify-between pt-2">
    <% if local_assigns[:show_cancel] %>
      <%= link_to "Cancel", activities_path, class: "text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" %>
    <% else %>
      <div></div>
    <% end %>
    <%= f.submit "Publish post", class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all shadow-sm cursor-pointer" %>
  </div>
<% end %>
