<%= content_for :title, "New Post" %>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">New Post</h1>

  <%= form_with model: @activity, class: "bg-white rounded-lg shadow p-6 border border-gray-100" do |f| %>
    <%= f.hidden_field :verb %>

    <div class="mb-4">
      <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, name: "activity[text][title]", value: params.dig(:activity, :text, :title), class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :body, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :body, name: "activity[text][body]", value: params.dig(:activity, :text, :body), rows: 4, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="flex items-center justify-between">
      <%= f.submit "Post", class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancel", activities_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    </div>
  <% end %>
</div>
