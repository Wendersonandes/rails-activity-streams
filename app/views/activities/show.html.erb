<%= content_for :title, "Post" %>

<div class="max-w-2xl mx-auto space-y-6">
  <div class="flex items-center gap-2">
    <%= link_to activities_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
      <i data-lucide="arrow-left" class="w-5 h-5"></i>
    <% end %>
    <span class="text-sm font-medium text-gray-500">Back to Feed</span>
  </div>

  <%= render "shared/activity", activity: @activity %>

  <% if @activity.children.any? %>
    <div class="space-y-3">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-400 flex items-center gap-1.5 px-1">
        <i data-lucide="message-square" class="w-3.5 h-3.5"></i>
        <span>Comments (<%= @activity.children.size %>)</span>
      </h3>
      <div class="space-y-3 border-l border-gray-200 pl-4 ml-5">
        <% @activity.children.includes(:author, :activity_objects).each do |child| %>
          <%= render "shared/activity", activity: child %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
