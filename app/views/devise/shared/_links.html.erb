<div class="mt-6 flex flex-col items-center gap-3 text-sm">
  <div class="w-full flex items-center gap-3 text-gray-400 text-xs uppercase tracking-wider">
    <span class="flex-1 border-t border-gray-200"></span>
    <span>or</span>
    <span class="flex-1 border-t border-gray-200"></span>
  </div>

  <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1.5">
    <%- if controller_name != 'sessions' %>
      <%= link_to "Sign in", new_session_path(resource_name), class: "text-blue-600 hover:text-blue-700 font-medium" %>
    <% end %>

    <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
      <%= link_to "Sign up", new_registration_path(resource_name), class: "text-blue-600 hover:text-blue-700 font-medium" %>
    <% end %>

    <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
      <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-gray-500 hover:text-gray-700" %>
    <% end %>

    <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
      <%= link_to "Resend confirmation", new_confirmation_path(resource_name), class: "text-gray-500 hover:text-gray-700" %>
    <% end %>

    <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
      <%= link_to "Resend unlock", new_unlock_path(resource_name), class: "text-gray-500 hover:text-gray-700" %>
    <% end %>

    <%- if devise_mapping.omniauthable? %>
      <%- resource_class.omniauth_providers.each do |provider| %>
        <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "text-blue-600 hover:text-blue-700 font-medium bg-transparent border-0 cursor-pointer" %>
      <% end %>
    <% end %>
  </div>
</div>
