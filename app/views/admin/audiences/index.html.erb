<%= content_for :title, "Audiences" %>

<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Audiences</h1>

  <div class="bg-white rounded-lg shadow border border-gray-100">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-100">
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">Activity</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">Relation</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @audiences.each do |audience| %>
          <tr>
            <td class="p-3 text-sm text-gray-900">
              <%= link_to audience.activity.verb, activity_path(audience.activity), class: "hover:underline" rescue "N/A" %>
            </td>
            <td class="p-3 text-sm text-gray-500"><%= audience.relation.name %></td>
            <td class="p-3 text-sm text-gray-400"><%= time_ago_in_words(audience.created_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-6 flex justify-center"><%== pagy_nav(@pagy) %></div>
  <% end %>
</div>
