<%= content_for :title, "Permissions" %>

<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Permissions</h1>

  <div class="bg-white rounded-lg shadow border border-gray-100">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-100">
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">Action</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">Object</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">ID</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @permissions.each do |perm| %>
          <tr>
            <td class="p-3 text-sm text-gray-900"><%= perm.action %></td>
            <td class="p-3 text-sm text-gray-500"><%= perm.object || "nil" %></td>
            <td class="p-3 text-sm text-gray-400"><%= perm.id %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
