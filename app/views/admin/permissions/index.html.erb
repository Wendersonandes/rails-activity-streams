<%= content_for :title, "Permissions" %>

<div class="max-w-4xl mx-auto space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Permissions</h1>
    <p class="text-xs text-gray-500 mt-0.5">Actions mapped to system objects</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200/80 shadow-sm overflow-hidden">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-gray-50/50 border-b border-gray-200">
          <th class="text-[10px] font-bold uppercase tracking-wider text-gray-400 p-4 w-1/3">Action</th>
          <th class="text-[10px] font-bold uppercase tracking-wider text-gray-400 p-4 w-1/3">Object</th>
          <th class="text-[10px] font-bold uppercase tracking-wider text-gray-400 p-4 w-1/3">ID</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @permissions.each do |perm| %>
          <tr class="hover:bg-gray-50/30 transition-colors">
            <td class="p-4 text-sm font-semibold text-gray-900"><%= perm.action %></td>
            <td class="p-4 text-sm text-gray-600"><%= perm.object || "nil" %></td>
            <td class="p-4 text-xs text-gray-400 font-medium"><%= perm.id %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
