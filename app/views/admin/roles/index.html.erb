<%= content_for :title, "Platform Roles" %>

<div class="max-w-3xl mx-auto space-y-6" data-controller="role-search">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Platform Roles</h1>
      <p class="text-xs text-gray-500 mt-0.5">
        Manage global permissions for <strong><%= Site.instance.name %></strong>
        &middot; <strong><%= @total_members %></strong> total members
      </p>
    </div>
  </div>

  <!-- User Role Search Panel -->
  <div class="bg-gray-50/50 border border-gray-200/80 rounded-xl p-5 shadow-sm space-y-3">
    <h3 class="text-sm font-semibold text-gray-900 flex items-center gap-1.5">
      <i data-lucide="search" class="w-4 h-4 text-blue-600"></i>
      <span>Find & Change User Role</span>
    </h3>
    <div class="relative">
      <input type="text"
             data-role-search-target="query"
             data-action="input->role-search#search"
             placeholder="Search platform members by name..."
             class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow"
             autocomplete="off">
      <div data-role-search-target="results"
           class="absolute z-10 w-full bg-white border border-gray-200 rounded-lg shadow-lg mt-1 hidden max-h-48 overflow-y-auto divide-y divide-gray-50">
      </div>
    </div>
    <input type="hidden" data-role-search-target="actorSlug">
    <input type="hidden" data-role-search-target="currentRole">
    
    <div data-role-search-target="detail" class="mt-3 hidden">
      <div class="bg-white border border-gray-200 rounded-lg px-4 py-3 flex items-center justify-between shadow-sm">
        <div>
          <p class="text-sm font-semibold text-gray-900" data-role-search-target="actorName"></p>
          <p class="text-xs text-gray-400 font-medium">Current role: <span class="font-bold text-gray-600" data-role-search-target="currentRoleLabel"></span></p>
        </div>
        <div class="flex items-center gap-2">
          <select data-role-search-target="newRole"
                  class="text-xs border border-gray-300 rounded px-2.5 py-1.5 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="admin">Admin</option>
            <option value="editor">Editor</option>
            <option value="moderator">Moderator</option>
            <option value="member">Member</option>
            <option value="silenced">Silenced</option>
            <option value="banned">Banned</option>
          </select>
          <button data-action="click->role-search#save"
                  data-role-search-target="saveBtn"
                  data-submit-url="<%= admin_roles_path %>/"
                  class="inline-flex items-center gap-1 text-xs bg-blue-600 hover:bg-blue-700 text-white font-medium px-3 py-1.5 rounded-md shadow-sm transition-colors cursor-pointer border-0">
            <i data-lucide="save" class="w-3.5 h-3.5"></i>
            <span>Save</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <% sections = [
       { label: "Admins",    items: @admins,    color: "bg-blue-50 text-blue-700 border-blue-100" },
       { label: "Editors",   items: @editors,   color: "bg-indigo-50 text-indigo-700 border-indigo-100" },
       { label: "Moderators", items: @moderators, color: "bg-emerald-50 text-emerald-700 border-emerald-100" },
       { label: "Silenced",  items: @silenced,  color: "bg-amber-50 text-amber-700 border-amber-100" },
       { label: "Banned",    items: @banned,    color: "bg-red-50 text-red-700 border-red-100" }
     ] %>

  <% sections.each do |section| %>
    <% next if section[:items].none? %>
    <div class="space-y-3">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-1">
        <%= section[:label] %> (<%= section[:items].count %>)
      </h3>
      <div class="space-y-2">
        <% section[:items].each do |actor| %>
          <div class="flex items-center justify-between bg-white border border-gray-200/60 rounded-xl p-4 shadow-sm hover:border-gray-300 transition-all duration-200">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center text-gray-500 font-bold text-sm border border-gray-200 flex-shrink-0">
                <%= actor.name[0].upcase %>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= link_to actor.name, public_path_for(actor), class: "hover:text-blue-600 transition-colors" %></p>
                <span class="text-[10px] font-medium px-2 py-0.5 rounded border <%= section[:color] %>"><%= section[:label].singularize %></span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <%= form_with url: admin_role_path(actor), method: :patch, class: "flex items-center gap-1.5" do |f| %>
                <%= f.hidden_field :from_role, value: section[:label].downcase.singularize %>
                <%= f.select :to_role, [["Admin", "admin"], ["Editor", "editor"], ["Moderator", "moderator"], ["Member", "member"], ["Silenced", "silenced"], ["Banned", "banned"]], { selected: section[:label].downcase.singularize }, { class: "text-xs border border-gray-300 rounded px-2 py-1 bg-white focus:outline-none" } %>
                <%= f.submit "Save", class: "text-xs bg-blue-600 hover:bg-blue-700 text-white px-2.5 py-1.2 rounded-md font-medium cursor-pointer border-0 shadow-sm transition-colors" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if sections.all? { |s| s[:items].none? } %>
    <div class="text-center text-gray-500 py-16 bg-white rounded-xl border border-gray-200/80 p-8 shadow-sm">
      <div class="w-12 h-12 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3 border border-gray-100">
        <i data-lucide="shield-alert" class="w-6 h-6 text-gray-400"></i>
      </div>
      <h3 class="text-base font-semibold text-gray-900">No special roles</h3>
      <p class="text-sm text-gray-500 mt-1 max-w-sm mx-auto">All users currently hold standard member permissions.</p>
    </div>
  <% end %>
</div>
