<%= content_for :title, "Platform Roles" %>

<div class="max-w-3xl mx-auto" data-controller="role-search">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Platform Roles</h1>
    <p class="text-sm text-gray-500 mt-1">
      Manage global permissions — site: <strong><%= Site.instance.name %></strong>
      &middot; <strong><%= @total_members %></strong> total members
    </p>
  </div>

  <div class="bg-gray-50 rounded-lg p-4 mb-6 border border-gray-200">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">Find & Change User Role</h3>
    <div class="flex gap-2">
      <div class="relative flex-1">
        <input type="text"
               data-role-search-target="query"
               data-action="input->role-search#search"
               placeholder="Search by name..."
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
               autocomplete="off">
        <div data-role-search-target="results"
             class="absolute z-10 w-full bg-white border border-gray-200 rounded-lg shadow-lg mt-1 hidden max-h-48 overflow-y-auto">
        </div>
      </div>
      <input type="hidden" data-role-search-target="actorSlug">
      <input type="hidden" data-role-search-target="currentRole">
    </div>
    <div data-role-search-target="detail" class="mt-3 hidden">
      <div class="bg-white border border-gray-200 rounded-lg px-4 py-3 flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-gray-900" data-role-search-target="actorName"></p>
          <p class="text-xs text-gray-500">Current role: <span data-role-search-target="currentRoleLabel"></span></p>
        </div>
        <div class="flex items-center gap-2">
          <select data-role-search-target="newRole"
                  class="text-xs border border-gray-300 rounded px-2 py-1">
            <option value="admin">Admin</option>
            <option value="editor">Editor</option>
            <option value="moderator">Moderator</option>
            <option value="member">Member</option>
            <option value="silenced">Silenced</option>
            <option value="banned">Banned</option>
          </select>
          <button data-action="click->role-search#save"
                  data-role-search-target="saveBtn"
                  data-submit-url="<%= admin_roles_path %>/"
                  class="text-xs bg-blue-600 text-white px-3 py-1.5 rounded hover:bg-blue-700 cursor-pointer">
            Save
          </button>
        </div>
      </div>
    </div>
  </div>

  <% sections = [
       { label: "Admins",    items: @admins },
       { label: "Editors",   items: @editors },
       { label: "Moderators", items: @moderators },
       { label: "Silenced",  items: @silenced },
       { label: "Banned",    items: @banned }
     ] %>

  <% sections.each do |section| %>
    <% next if section[:items].none? %>
    <div class="mb-6">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
        <%= section[:label] %> (<%= section[:items].count %>)
      </h3>
      <div class="space-y-2">
        <% section[:items].each do |actor| %>
          <div class="flex items-center justify-between bg-white border border-gray-100 rounded-lg px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gray-200 rounded-full flex items-center justify-center text-gray-500 text-sm font-bold"><%= actor.name[0].upcase %></div>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= link_to actor.name, actor_path(actor), class: "hover:underline" %></p>
                <p class="text-xs text-gray-500"><%= section[:label].singularize %></p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <%= form_with url: admin_role_path(actor), method: :patch, class: "flex items-center gap-1" do |f| %>
                <%= f.hidden_field :from_role, value: section[:label].downcase.singularize %>
                <%= f.select :to_role, [["Admin", "admin"], ["Editor", "editor"], ["Moderator", "moderator"], ["Member", "member"], ["Silenced", "silenced"], ["Banned", "banned"]], { selected: section[:label].downcase.singularize }, { class: "text-xs border border-gray-300 rounded px-2 py-1" } %>
                <%= f.submit "Save", class: "text-xs bg-blue-600 text-white px-2 py-1 rounded hover:bg-blue-700 cursor-pointer" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if sections.all? { |s| s[:items].none? } %>
    <div class="text-center text-gray-500 py-12">
      <p>No users with special roles yet.</p>
    </div>
  <% end %>
</div>
