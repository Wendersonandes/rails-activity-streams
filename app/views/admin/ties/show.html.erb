<%= content_for :title, "Tie ##{@tie.id}" %>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Tie Details</h1>

  <div class="bg-white rounded-lg shadow p-6 border border-gray-100">
    <dl class="space-y-3">
      <div><dt class="text-xs font-semibold text-gray-500 uppercase">Sender</dt><dd class="text-gray-900"><%= @tie.sender.name %></dd></div>
      <div><dt class="text-xs font-semibold text-gray-500 uppercase">Receiver</dt><dd class="text-gray-900"><%= @tie.receiver.name %></dd></div>
      <div><dt class="text-xs font-semibold text-gray-500 uppercase">Relation</dt><dd class="text-gray-900"><%= @tie.relation.name %> (<%= @tie.relation.type %>)</dd></div>
      <div><dt class="text-xs font-semibold text-gray-500 uppercase">Contact ID</dt><dd class="text-gray-400"><%= @tie.contact_id %></dd></div>
    </dl>
  </div>

  <%= link_to "Back to Ties", admin_ties_path, class: "text-sm text-blue-600 hover:underline mt-4 inline-block" %>
</div>
