<%= content_for :title, "Tie ##{@tie.id}" %>

<div class="max-w-lg mx-auto space-y-6">
  <div class="flex items-center gap-3">
    <%= link_to admin_ties_path, class: "p-2 hover:bg-gray-100 rounded-lg text-gray-500 hover:text-gray-900 transition-colors" do %>
      <i data-lucide="arrow-left" class="w-5 h-5"></i>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Tie Details</h1>
      <p class="text-xs text-gray-500 mt-0.5">Deep inspection of relationship data</p>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200/80 p-6 shadow-sm">
    <dl class="space-y-4 divide-y divide-gray-100">
      <div class="flex justify-between py-3 first:pt-0">
        <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Sender</dt>
        <dd class="text-sm font-semibold text-gray-950"><%= @tie.sender.name %></dd>
      </div>
      <div class="flex justify-between py-3">
        <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Receiver</dt>
        <dd class="text-sm font-semibold text-gray-950"><%= @tie.receiver.name %></dd>
      </div>
      <div class="flex justify-between py-3">
        <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Relation</dt>
        <dd class="text-sm font-semibold text-gray-950">
          <%= @tie.relation.name %>
          <span class="text-xs text-gray-400 font-medium ml-1">(<%= @tie.relation.type %>)</span>
        </dd>
      </div>
      <div class="flex justify-between py-3 last:pb-0">
        <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Contact ID</dt>
        <dd class="text-xs text-gray-500 font-mono"><%= @tie.contact_id %></dd>
      </div>
    </dl>
  </div>
</div>
