<%= content_for :title, "Ties" %>

<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Ties</h1>

  <div class="bg-white rounded-lg shadow border border-gray-100">
    <table class="w-full">
      <thead>
        <tr class="border-b border-gray-100">
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">ID</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">Sender</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">Receiver</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">Relation</th>
          <th class="text-left text-xs font-semibold text-gray-500 uppercase p-3">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @ties.each do |tie| %>
          <tr>
            <td class="p-3 text-sm text-gray-400"><%= tie.id %></td>
            <td class="p-3 text-sm text-gray-900"><%= tie.sender.name %></td>
            <td class="p-3 text-sm text-gray-900"><%= tie.receiver.name %></td>
            <td class="p-3 text-sm text-gray-500"><%= tie.relation.name %></td>
            <td class="p-3 text-sm text-gray-400"><%= time_ago_in_words(tie.created_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-6 flex justify-center"><%== pagy_nav(@pagy) %></div>
  <% end %>
</div>
