<%= content_for :title, "Ties" %>

<div class="max-w-4xl mx-auto space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Ties</h1>
    <p class="text-xs text-gray-500 mt-0.5">Active relationships and permissions established between actors</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200/80 shadow-sm overflow-hidden">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-gray-50/50 border-b border-gray-200">
          <th class="text-[10px] font-bold uppercase tracking-wider text-gray-400 p-4">ID</th>
          <th class="text-[10px] font-bold uppercase tracking-wider text-gray-400 p-4">Sender</th>
          <th class="text-[10px] font-bold uppercase tracking-wider text-gray-400 p-4">Receiver</th>
          <th class="text-[10px] font-bold uppercase tracking-wider text-gray-400 p-4">Relation</th>
          <th class="text-[10px] font-bold uppercase tracking-wider text-gray-400 p-4">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @ties.each do |tie| %>
          <tr class="hover:bg-gray-50/30 transition-colors">
            <td class="p-4 text-xs text-gray-400 font-medium"><%= tie.id %></td>
            <td class="p-4 text-sm font-semibold text-gray-950"><%= tie.sender.name %></td>
            <td class="p-4 text-sm font-semibold text-gray-950"><%= tie.receiver.name %></td>
            <td class="p-4 text-sm text-gray-600 font-medium"><%= tie.relation.name %></td>
            <td class="p-4 text-xs text-gray-400 font-medium"><%= time_ago_in_words(tie.created_at) %> ago</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="mt-6 flex justify-center"><%== pagy_nav(@pagy) %></div>
  <% end %>
</div>
