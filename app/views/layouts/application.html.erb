<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
  <head>
    <title><%= content_for(:title) || "Social Stream" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Social Stream">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Styles and JS -->
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
      function initLucide() {
        if (typeof lucide !== 'undefined') {
          lucide.createIcons();
        }
      }
      document.addEventListener("turbo:load", initLucide);
      document.addEventListener("turbo:render", initLucide);
      document.addEventListener("turbo:before-stream-render", (event) => {
        const originalRender = event.detail.render;
        event.detail.render = function(streamElement) {
          originalRender(streamElement);
          initLucide();
        };
      });
    </script>
  </head>

  <body id="body" class="h-full bg-gray-50/50 text-gray-900 font-sans antialiased">
    <%= render "shared/nav" %>
    <main class="min-h-screen pt-20 pb-12">
      <div class="container mx-auto px-5">
        <%= render "shared/flash" %>
        
        <% if current_actor && !devise_controller? && !content_for?(:no_sidebar) %>
          <div class="max-w-6xl mx-auto">
            <div class="grid grid-cols-12 gap-6">
              <!-- Left Column -->
              <div class="hidden lg:block lg:col-span-3">
                <%= content_for?(:left_sidebar) ? yield(:left_sidebar) : render("shared/left_sidebar") %>
              </div>

              <!-- Center Column -->
              <div class="col-span-12 <%= content_for?(:right_sidebar) ? 'lg:col-span-6' : 'lg:col-span-9' %> space-y-6">
                <%= yield %>
              </div>

              <!-- Right Column -->
              <% if content_for?(:right_sidebar) %>
                <div class="hidden lg:block lg:col-span-3">
                  <%= yield :right_sidebar %>
                </div>
              <% end %>
            </div>
          </div>
        <% else %>
          <%= yield %>
        <% end %>
      </div>
    </main>
    <%= turbo_frame_tag "modal" %>
  </body>
</html>
