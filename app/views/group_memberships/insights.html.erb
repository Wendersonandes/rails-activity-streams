<%= content_for :title, "#{@group.name} — Insights" %>

<div class="max-w-2xl mx-auto space-y-6">
  <!-- Group Header Card -->
  <div class="bg-white rounded-xl border border-gray-200/80 p-5 shadow-sm">
    <div class="flex items-start gap-4">
      <div class="w-12 h-12 bg-white rounded-lg p-1 shadow-sm flex-shrink-0 border border-gray-150 overflow-hidden">
        <% if @group.actor.avatar.attached? %>
          <%= image_tag @group.actor.avatar.variant(:thumb), class: "w-full h-full rounded-lg object-cover" %>
        <% else %>
          <div class="w-full h-full rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center font-bold text-lg border border-emerald-100">
            <%= @group.name.first.upcase %>
          </div>
        <% end %>
      </div>
      <div class="flex-1 min-w-0">
        <h1 class="text-xl font-bold text-gray-900 tracking-tight truncate"><%= @group.name %></h1>
        <% if @group.description.present? %>
          <p class="text-xs text-gray-500 mt-0.5 truncate"><%= @group.description %></p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Tab Navigation -->
  <div class="flex border-b border-gray-200/80 bg-white/50 p-1 rounded-lg border border-gray-100/50">
    <%= link_to group_path(@group), class: "flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-md transition-all text-gray-500 hover:text-gray-900" do %>
      <i data-lucide="message-square" class="w-4 h-4"></i>
      <span>Posts</span>
    <% end %>
    <%= link_to group_memberships_path(@group), class: "flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-md transition-all text-gray-500 hover:text-gray-900" do %>
      <i data-lucide="users" class="w-4 h-4"></i>
      <span>Members (<%= @group.actor.sent_contacts.active.count %>)</span>
    <% end %>
    <span class="flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-md bg-white text-blue-600 shadow-sm border border-gray-150">
      <i data-lucide="bar-chart-3" class="w-4 h-4"></i>
      <span>Insights</span>
    </span>
  </div>

  <!-- Minimal Stats Cards -->
  <div class="grid grid-cols-3 gap-4">
    <div class="bg-white border border-gray-200/80 rounded-xl p-4 shadow-sm space-y-1">
      <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">New Members</span>
      <div class="flex items-baseline gap-1">
        <p class="text-3xl font-bold text-blue-700">+<%= @stats[:new_members] %></p>
        <span class="text-[10px] text-gray-450 font-medium">last 7d</span>
      </div>
    </div>
    
    <div class="bg-white border border-gray-200/80 rounded-xl p-4 shadow-sm space-y-1">
      <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">New Posts</span>
      <div class="flex items-baseline gap-1">
        <p class="text-3xl font-bold text-green-700"><%= @stats[:new_posts] %></p>
        <span class="text-[10px] text-gray-450 font-medium">last 7d</span>
      </div>
    </div>

    <div class="bg-white border border-gray-200/80 rounded-xl p-4 shadow-sm space-y-1">
      <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">Active Users</span>
      <div class="flex items-baseline gap-1">
        <p class="text-3xl font-bold text-purple-700"><%= @stats[:active_members] %></p>
        <span class="text-[10px] text-gray-450 font-medium">last 7d</span>
      </div>
    </div>
  </div>

  <!-- Member Growth Progress Bars -->
  <div class="bg-white rounded-xl border border-gray-200/80 p-5 shadow-sm space-y-4">
    <h3 class="text-sm font-semibold text-gray-900 flex items-center gap-1.5 pb-1 border-b border-gray-50">
      <i data-lucide="trending-up" class="w-4 h-4 text-blue-600"></i>
      <span>Member Growth (Daily)</span>
    </h3>
    <% if @stats[:daily_members].any? %>
      <div class="space-y-3">
        <% max = @stats[:daily_members].values.max %>
        <% @stats[:daily_members].each do |day, count| %>
          <div class="flex items-center gap-3">
            <span class="text-xs text-gray-450 font-medium w-10 text-right"><%= day %></span>
            <div class="flex-1 bg-gray-100 rounded-full h-4 overflow-hidden">
              <div class="bg-blue-600 h-full rounded-full transition-all duration-300" style="width: <%= max > 0 ? (count.to_f / max * 100).round : 0 %>%"></div>
            </div>
            <span class="text-xs font-semibold text-gray-800 w-5 text-right"><%= count %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-6">
        <p class="text-xs text-gray-405">No growth registered in the last 7 days.</p>
      </div>
    <% end %>
  </div>

  <!-- Top Contributors List -->
  <div class="bg-white rounded-xl border border-gray-200/80 p-5 shadow-sm space-y-4">
    <h3 class="text-sm font-semibold text-gray-900 flex items-center gap-1.5 pb-1 border-b border-gray-50">
      <i data-lucide="award" class="w-4 h-4 text-blue-600"></i>
      <span>Top Contributors (All-time)</span>
    </h3>
    <% if @stats[:top_contributors].any? %>
      <div class="divide-y divide-gray-100">
        <% @stats[:top_contributors].each_with_index do |item, i| %>
          <% actor = item[:actor] %>
          <div class="flex items-center gap-3 py-3 first:pt-0 last:pb-0">
            <span class="text-xs font-bold text-gray-400 w-6">#<%= i + 1 %></span>
            <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 overflow-hidden border border-gray-100">
              <% if actor.avatar.attached? %>
                <%= image_tag actor.avatar.variant(:thumb), class: "w-8 h-8 rounded-full object-cover" %>
              <% else %>
                <span class="bg-gray-50 w-full h-full flex items-center justify-center text-gray-500"><%= actor.name[0].upcase %></span>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate"><%= link_to actor.name, public_path_for(actor), class: "hover:text-blue-600 transition-colors" %></p>
            </div>
            <span class="text-xs font-semibold text-gray-500 bg-gray-50 border border-gray-200 px-2 py-1 rounded-md flex-shrink-0"><%= item[:count] %> posts</span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-6">
        <p class="text-xs text-gray-405">No posts published yet.</p>
      </div>
    <% end %>
  </div>
</div>
