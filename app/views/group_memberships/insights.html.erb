<%= content_for :title, "#{@group.name} — Insights" %>

<div class="max-w-2xl mx-auto">
  <div class="bg-white rounded-lg shadow p-6 mb-4 border border-gray-100">
    <div class="flex items-start gap-4">
      <div class="w-16 h-16 bg-gray-200 rounded-lg flex items-center justify-center text-gray-500 text-xl font-bold flex-shrink-0">
        G
      </div>
      <div class="flex-1">
        <h1 class="text-2xl font-bold text-gray-900"><%= @group.name %></h1>
        <% if @group.description.present? %>
          <p class="text-gray-600 mt-1"><%= @group.description %></p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex border-b border-gray-200 mb-6">
    <%= link_to "Posts", group_path(@group), class: "px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700" %>
    <%= link_to "Members (#{@group.actor.sent_contacts.active.count})", group_memberships_path(@group), class: "px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700" %>
    <span class="px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-600">Insights</span>
  </div>

  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-blue-50 rounded-lg p-4 border border-blue-100">
      <p class="text-3xl font-bold text-blue-700">+<%= @stats[:new_members] %></p>
      <p class="text-xs text-blue-600 mt-1">New Members</p>
      <p class="text-xs text-blue-400">last 7 days</p>
    </div>
    <div class="bg-green-50 rounded-lg p-4 border border-green-100">
      <p class="text-3xl font-bold text-green-700"><%= @stats[:new_posts] %></p>
      <p class="text-xs text-green-600 mt-1">New Posts</p>
      <p class="text-xs text-green-400">last 7 days</p>
    </div>
    <div class="bg-purple-50 rounded-lg p-4 border border-purple-100">
      <p class="text-3xl font-bold text-purple-700"><%= @stats[:active_members] %></p>
      <p class="text-xs text-purple-600 mt-1">Active Members</p>
      <p class="text-xs text-purple-400">last 7 days</p>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow p-4 mb-6 border border-gray-100">
    <h3 class="text-sm font-semibold text-gray-900 mb-3">Member Growth (daily)</h3>
    <% if @stats[:daily_members].any? %>
      <div class="space-y-2">
        <% max = @stats[:daily_members].values.max %>
        <% @stats[:daily_members].each do |day, count| %>
          <div class="flex items-center gap-3">
            <span class="text-xs text-gray-500 w-10 text-right"><%= day %></span>
            <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
              <div class="bg-blue-500 h-full rounded-full transition-all" style="width: <%= max > 0 ? (count.to_f / max * 100).round : 0 %>%"></div>
            </div>
            <span class="text-xs font-medium text-gray-700 w-4"><%= count %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400 py-4">No new members in the last 7 days.</p>
    <% end %>
  </div>

  <div class="bg-white rounded-lg shadow p-4 mb-6 border border-gray-100">
    <h3 class="text-sm font-semibold text-gray-900 mb-3">Top Contributors (all time)</h3>
    <% if @stats[:top_contributors].any? %>
      <div class="space-y-2">
        <% @stats[:top_contributors].each_with_index do |item, i| %>
          <% actor = item[:actor] %>
          <div class="flex items-center gap-3">
            <span class="text-xs font-bold text-gray-400 w-6">#<%= i + 1 %></span>
            <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center text-gray-500 text-xs font-bold"><%= actor.name[0].upcase %></div>
            <div class="flex-1">
              <p class="text-sm font-medium text-gray-900"><%= link_to actor.name, actor_path(actor), class: "hover:underline" %></p>
            </div>
            <span class="text-sm font-semibold text-gray-700"><%= item[:count] %> posts</span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400 py-4">No posts yet.</p>
    <% end %>
  </div>
</div>
