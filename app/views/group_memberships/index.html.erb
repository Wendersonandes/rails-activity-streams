<%= content_for :title, "#{@group.name} — Members" %>

<div class="max-w-2xl mx-auto space-y-6" data-controller="member-search"
     data-member-exclude="<%= (@admins + @moderators + @members).map(&:id).join(",") %>">
  
  <!-- Group Header Card -->
  <div class="bg-white rounded-xl border border-gray-200/80 p-5 shadow-sm">
    <div class="flex items-start gap-4">
      <div class="w-12 h-12 bg-white rounded-lg p-1 shadow-sm flex-shrink-0 border border-gray-200 overflow-hidden">
        <% if @group.actor.avatar.attached? %>
          <%= image_tag @group.actor.avatar.variant(:thumb), class: "w-full h-full rounded-lg object-cover" %>
        <% else %>
          <div class="w-full h-full rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center font-bold text-lg border border-emerald-100">
            <%= @group.name.first.upcase %>
          </div>
        <% end %>
      </div>
      <div class="flex-1 min-w-0">
        <h1 class="text-xl font-bold text-gray-900 tracking-tight truncate"><%= @group.name %></h1>
        <% if @group.description.present? %>
          <p class="text-xs text-gray-500 mt-0.5 truncate"><%= @group.description %></p>
        <% end %>
        <div class="flex gap-4 mt-2 text-xs text-gray-400 font-medium">
          <span><%= @total_posts %> posts</span>
          <span><%= @total_members %> members</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab Navigation -->
  <%= render "groups/navigation" %>


  <!-- Add Member Panel -->
  <% if @is_admin %>
    <div class="bg-gray-50/50 border border-gray-200/80 rounded-xl p-5 shadow-sm space-y-3">
      <h3 class="text-sm font-semibold text-gray-900 flex items-center gap-1.5">
        <i data-lucide="user-plus" class="w-4 h-4 text-blue-600"></i>
        <span>Add Member</span>
      </h3>
      <div class="flex gap-2">
        <div class="relative flex-1">
          <input type="text"
                 data-member-search-target="query"
                 data-action="input->member-search#search"
                 placeholder="Search colleagues by name..."
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow"
                 autocomplete="off">
          <div data-member-search-target="results"
               class="absolute z-10 w-full bg-white border border-gray-200 rounded-lg shadow-lg mt-1 hidden max-h-48 overflow-y-auto divide-y divide-gray-50">
          </div>
        </div>
        <select data-member-search-target="role"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="member">Member</option>
          <option value="moderator">Moderator</option>
          <option value="admin">Admin</option>
        </select>
        <button data-action="click->member-search#add"
                data-member-search-target="addBtn"
                data-submit-url="<%= group_memberships_path(@group) %>"
                data-group-id="<%= @group.id %>"
                disabled
                class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
          Add
        </button>
      </div>
      <input type="hidden" data-member-search-target="actorId">
    </div>
  <% end %>

  <!-- Pending Requests Panel -->
  <% if @is_admin && @pending_requests.any? %>
    <div class="bg-yellow-50/60 border border-yellow-200/80 rounded-xl p-5 shadow-sm space-y-4">
      <h3 class="text-sm font-semibold text-yellow-800 flex items-center gap-1.5">
        <i data-lucide="clock" class="w-4 h-4 text-yellow-600"></i>
        <span>Pending Requests (<%= @pending_requests.count %>)</span>
      </h3>
      <div class="space-y-3">
        <% @pending_requests.each do |contact| %>
          <div class="flex items-center justify-between bg-white border border-yellow-100 rounded-lg p-3.5 shadow-sm">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-yellow-100 text-yellow-800 flex items-center justify-center font-bold text-sm border border-yellow-200 flex-shrink-0">
                <% if contact.sender.avatar.attached? %>
                  <%= image_tag contact.sender.avatar.variant(:thumb), class: "w-full h-full rounded-full object-cover" %>
                <% else %>
                  <span><%= contact.sender.name[0].upcase %></span>
                <% end %>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-gray-900 truncate"><%= link_to contact.sender.name, public_path_for(contact.sender), class: "hover:text-blue-600 transition-colors" %></p>
                <p class="text-[10px] text-gray-400 font-medium"><%= time_ago_in_words(contact.created_at) %> ago</p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <%= form_with url: approve_request_group_memberships_path(@group), method: :post, class: "flex items-center gap-1.5" do |f| %>
                <%= f.hidden_field :contact_id, value: contact.id %>
                <%= f.select :role, [["Member", "member"], ["Moderator", "moderator"], ["Admin", "admin"]], {}, class: "text-xs border border-gray-300 rounded px-2 py-1 bg-white focus:outline-none" %>
                <%= f.submit "Approve", class: "text-xs bg-emerald-600 hover:bg-emerald-700 text-white px-2.5 py-1.2 rounded-md font-medium cursor-pointer border-0 shadow-sm transition-colors" %>
              <% end %>
              <%= button_to "Reject", reject_request_group_memberships_path(@group, contact_id: contact.id), method: :post, class: "text-xs text-red-600 hover:text-red-700 font-medium bg-transparent border-0 cursor-pointer transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Invites Panel -->
  <% if current_actor %>
    <% already_member = @member_roles.any? %>
    <% my_invites = already_member ? Contact.none : current_actor.received_contacts.pending.where(sender: @group_actor) %>
    <% if my_invites.any? %>
      <div class="bg-blue-50/60 border border-blue-200/80 rounded-xl p-5 shadow-sm space-y-4">
        <h3 class="text-sm font-semibold text-blue-800 flex items-center gap-1.5">
          <i data-lucide="mail-open" class="w-4 h-4 text-blue-600"></i>
          <span>Your Invites</span>
        </h3>
        <div class="space-y-3">
          <% my_invites.each do |contact| %>
            <div class="flex items-center justify-between bg-white border border-blue-100 rounded-lg p-3.5 shadow-sm">
              <p class="text-sm text-gray-700">You were invited by <span class="font-bold text-gray-900"><%= contact.sender.name %></span></p>
              <div class="flex items-center gap-2 flex-shrink-0">
                <%= button_to accept_invite_group_memberships_path(@group), method: :post, class: "text-xs bg-emerald-600 hover:bg-emerald-700 text-white px-3 py-1.5 rounded-lg font-medium cursor-pointer border-0 shadow-sm transition-colors" %>
                <%= button_to "Decline", decline_invite_group_memberships_path(@group, contact_id: contact.id), method: :post, class: "text-xs text-red-600 hover:text-red-700 font-medium bg-transparent border-0 cursor-pointer transition-colors" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- Members Lists by Role -->
  
  <!-- Admins List -->
  <% if @admins.any? %>
    <div class="space-y-3">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-1">Admins (<%= @admins.count %>)</h3>
      <div class="space-y-2">
        <% @admins.each do |admin_actor| %>
          <div class="flex items-center justify-between bg-white border border-gray-200/60 rounded-xl p-4 shadow-sm hover:border-gray-300 transition-all duration-200">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 overflow-hidden">
                <% if admin_actor.avatar.attached? %>
                  <%= image_tag admin_actor.avatar.variant(:thumb), class: "w-10 h-10 rounded-full object-cover" %>
                <% else %>
                  <span class="bg-blue-50 w-full h-full flex items-center justify-center text-blue-600 border border-blue-100"><%= admin_actor.name[0].upcase %></span>
                <% end %>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= link_to admin_actor.name, public_path_for(admin_actor), class: "hover:text-blue-600 transition-colors" %></p>
                <p class="text-xs text-gray-400 font-medium">Administrator</p>
              </div>
            </div>
            <% if @is_admin && admin_actor != current_actor %>
              <div class="flex items-center gap-2">
                <%= form_with url: group_membership_path(@group, admin_actor), method: :patch, class: "flex items-center gap-1.5" do |f| %>
                  <%= f.hidden_field :from_role, value: "admin" %>
                  <%= f.select :to_role, [["Admin", "admin"], ["Moderator", "moderator"], ["Member", "member"]], { selected: "admin" }, { class: "text-xs border border-gray-300 rounded px-2 py-1 bg-white focus:outline-none" } %>
                  <%= f.submit "Save", class: "text-xs bg-blue-600 hover:bg-blue-700 text-white px-2.5 py-1.2 rounded-md font-medium cursor-pointer border-0 shadow-sm transition-colors" %>
                <% end %>
                <%= button_to group_membership_path(@group, admin_actor, role: "admin"), method: :delete, data: { turbo_confirm: "Are you sure you want to remove #{admin_actor.name} from the group?" }, class: "text-xs text-red-600 hover:text-red-800 font-medium bg-transparent border-0 cursor-pointer transition-colors" do %>
                  <i data-lucide="user-minus" class="w-4 h-4"></i>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Moderators List -->
  <% if @moderators.any? %>
    <div class="space-y-3 pt-2">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-1">Moderators (<%= @moderators.count %>)</h3>
      <div class="space-y-2">
        <% @moderators.each do |mod_actor| %>
          <div class="flex items-center justify-between bg-white border border-gray-200/60 rounded-xl p-4 shadow-sm hover:border-gray-300 transition-all duration-200">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 overflow-hidden">
                <% if mod_actor.avatar.attached? %>
                  <%= image_tag mod_actor.avatar.variant(:thumb), class: "w-10 h-10 rounded-full object-cover" %>
                <% else %>
                  <span class="bg-emerald-50 w-full h-full flex items-center justify-center text-emerald-600 border border-emerald-100"><%= mod_actor.name[0].upcase %></span>
                <% end %>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= link_to mod_actor.name, public_path_for(mod_actor), class: "hover:text-blue-600 transition-colors" %></p>
                <p class="text-xs text-gray-400 font-medium">Moderator</p>
              </div>
            </div>
            <% if @is_admin %>
              <div class="flex items-center gap-2">
                <%= form_with url: group_membership_path(@group, mod_actor), method: :patch, class: "flex items-center gap-1.5" do |f| %>
                  <%= f.hidden_field :from_role, value: "moderator" %>
                  <%= f.select :to_role, [["Admin", "admin"], ["Moderator", "moderator"], ["Member", "member"]], { selected: "moderator" }, { class: "text-xs border border-gray-300 rounded px-2 py-1 bg-white focus:outline-none" } %>
                  <%= f.submit "Save", class: "text-xs bg-blue-600 hover:bg-blue-700 text-white px-2.5 py-1.2 rounded-md font-medium cursor-pointer border-0 shadow-sm transition-colors" %>
                <% end %>
                <%= button_to group_membership_path(@group, mod_actor, role: "moderator"), method: :delete, data: { turbo_confirm: "Are you sure you want to remove #{mod_actor.name} from the group?" }, class: "text-xs text-red-600 hover:text-red-800 font-medium bg-transparent border-0 cursor-pointer transition-colors" do %>
                  <i data-lucide="user-minus" class="w-4 h-4"></i>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Members List -->
  <div class="space-y-3 pt-2">
    <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-1">Members (<%= @members.count %>)</h3>
    <% if @members.any? %>
      <div class="space-y-2">
        <% @members.each do |member_actor| %>
          <div class="flex items-center justify-between bg-white border border-gray-200/60 rounded-xl p-4 shadow-sm hover:border-gray-300 transition-all duration-200">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 overflow-hidden">
                <% if member_actor.avatar.attached? %>
                  <%= image_tag member_actor.avatar.variant(:thumb), class: "w-10 h-10 rounded-full object-cover" %>
                <% else %>
                  <span class="bg-gray-50 w-full h-full flex items-center justify-center text-gray-500 border border-gray-200"><%= member_actor.name[0].upcase %></span>
                <% end %>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= link_to member_actor.name, public_path_for(member_actor), class: "hover:text-blue-600 transition-colors" %></p>
                <p class="text-xs text-gray-400 font-medium">Member</p>
              </div>
            </div>
            <% if @is_admin %>
              <div class="flex items-center gap-2">
                <%= form_with url: group_membership_path(@group, member_actor), method: :patch, class: "flex items-center gap-1.5" do |f| %>
                  <%= f.hidden_field :from_role, value: "member" %>
                  <%= f.select :to_role, [["Admin", "admin"], ["Moderator", "moderator"], ["Member", "member"]], { selected: "member" }, { class: "text-xs border border-gray-300 rounded px-2 py-1 bg-white focus:outline-none" } %>
                  <%= f.submit "Save", class: "text-xs bg-blue-600 hover:bg-blue-700 text-white px-2.5 py-1.2 rounded-md font-medium cursor-pointer border-0 shadow-sm transition-colors" %>
                <% end %>
                <%= button_to group_membership_path(@group, member_actor, role: "member"), method: :delete, data: { turbo_confirm: "Are you sure you want to remove #{member_actor.name} from the group?" }, class: "text-xs text-red-600 hover:text-red-800 font-medium bg-transparent border-0 cursor-pointer transition-colors" do %>
                  <i data-lucide="user-minus" class="w-4 h-4"></i>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8 bg-white border border-gray-200/60 rounded-xl">
        <p class="text-sm text-gray-400 font-medium">No other members in this group yet.</p>
      </div>
    <% end %>
  </div>
</div>
