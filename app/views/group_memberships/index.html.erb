<%= content_for :title, "#{@group.name} — Members" %>

<div class="max-w-2xl mx-auto" data-controller="member-search"
     data-member-exclude="<%= (@admins + @moderators + @members).map(&:id).join(",") %>">
  <div class="bg-white rounded-lg shadow p-6 mb-4 border border-gray-100">
    <div class="flex items-start gap-4">
      <div class="w-16 h-16 bg-gray-200 rounded-lg flex items-center justify-center text-gray-500 text-xl font-bold flex-shrink-0">
        G
      </div>
      <div class="flex-1">
        <h1 class="text-2xl font-bold text-gray-900"><%= @group.name %></h1>
        <% if @group.description.present? %>
          <p class="text-gray-600 mt-1"><%= @group.description %></p>
        <% end %>
        <div class="flex gap-4 mt-2 text-sm text-gray-500">
          <span><%= @total_posts %> posts</span>
          <span><%= @total_members %> members</span>
        </div>
      </div>
    </div>
  </div>

  <div class="flex border-b border-gray-200 mb-6">
    <%= link_to "Posts", group_path(@group), class: "px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700" %>
    <span class="px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-600">
      Members (<%= @total_members %>)
    </span>
    <% if @is_admin %>
      <%= link_to "Insights", insights_group_memberships_path(@group), class: "px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700" %>
    <% end %>
  </div>

  <% if current_actor && @member_roles.any? %>
    <div class="mb-4 flex justify-end">
      <%= button_to "Leave Group", group_membership_path(@group, current_actor, role: @member_roles.first), method: :delete, data: { turbo_confirm: "Leave #{@group.name}?" }, class: "text-sm text-red-600 hover:text-red-800 bg-transparent border border-red-300 px-3 py-1.5 rounded hover:bg-red-50" %>
    </div>
  <% end %>

  <% if @is_admin %>
    <div class="bg-gray-50 rounded-lg p-4 mb-6 border border-gray-200">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">Add Member</h3>
      <div class="flex gap-2">
        <div class="relative flex-1">
          <input type="text"
                 data-member-search-target="query"
                 data-action="input->member-search#search"
                 placeholder="Search by name..."
                 class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                 autocomplete="off">
          <div data-member-search-target="results"
               class="absolute z-10 w-full bg-white border border-gray-200 rounded-lg shadow-lg mt-1 hidden max-h-48 overflow-y-auto">
          </div>
        </div>
        <select data-member-search-target="role"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
          <option value="member">Member</option>
          <option value="moderator">Moderator</option>
          <option value="admin">Admin</option>
        </select>
        <button data-action="click->member-search#add"
                data-member-search-target="addBtn"
                data-group-id="<%= @group.id %>"
                disabled
                class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed">
          Add
        </button>
      </div>
      <input type="hidden" data-member-search-target="actorId">
    </div>
  <% end %>

  <% if @is_admin && @pending_requests.any? %>
    <div class="bg-yellow-50 rounded-lg p-4 mb-6 border border-yellow-200">
      <h3 class="text-sm font-semibold text-yellow-800 mb-3">Pending Requests (<%= @pending_requests.count %>)</h3>
      <div class="space-y-2">
        <% @pending_requests.each do |contact| %>
          <div class="flex items-center justify-between bg-white border border-yellow-100 rounded-lg px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center text-yellow-600 text-sm font-bold"><%= contact.sender.name[0].upcase %></div>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= link_to contact.sender.name, actor_path(contact.sender), class: "hover:underline" %></p>
                <p class="text-xs text-yellow-600"><%= time_ago_in_words(contact.created_at) %> ago</p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <%= form_with url: approve_request_group_memberships_path(@group), method: :post, class: "flex items-center gap-1" do |f| %>
                <%= f.hidden_field :contact_id, value: contact.id %>
                <%= f.select :role, [["Member", "member"], ["Moderator", "moderator"], ["Admin", "admin"]], {}, class: "text-xs border border-gray-300 rounded px-2 py-1" %>
                <%= f.submit "Approve", class: "text-xs bg-green-600 text-white px-2 py-1 rounded hover:bg-green-700 cursor-pointer" %>
              <% end %>
              <%= button_to "Reject", reject_request_group_memberships_path(@group, contact_id: contact.id), method: :post, class: "text-xs text-red-500 hover:text-red-700" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if current_actor %>
    <% already_member = @member_roles.any? %>
    <% my_invites = already_member ? Contact.none : current_actor.received_contacts.pending.where(sender: @group_actor) %>
    <% if my_invites.any? %>
      <div class="bg-blue-50 rounded-lg p-4 mb-6 border border-blue-200">
        <h3 class="text-sm font-semibold text-blue-800 mb-3">Your Invites</h3>
        <div class="space-y-2">
          <% my_invites.each do |contact| %>
            <div class="flex items-center justify-between bg-white border border-blue-100 rounded-lg px-4 py-3">
              <p class="text-sm text-gray-700">You were invited by <span class="font-medium"><%= contact.sender.name %></span></p>
              <div class="flex items-center gap-2">
                <%= button_to "Accept", accept_invite_group_memberships_path(@group), method: :post, class: "text-xs bg-green-600 text-white px-3 py-1 rounded hover:bg-green-700 cursor-pointer" %>
                <%= button_to "Decline", decline_invite_group_memberships_path(@group, contact_id: contact.id), method: :post, class: "text-xs text-red-500 hover:text-red-700" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>

  <% if @admins.any? %>
    <div class="mb-6">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Admins (<%= @admins.count %>)</h3>
      <div class="space-y-2">
        <% @admins.each do |admin_actor| %>
          <div class="flex items-center justify-between bg-white border border-gray-100 rounded-lg px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 text-sm font-bold"><%= admin_actor.name[0].upcase %></div>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= link_to admin_actor.name, actor_path(admin_actor), class: "hover:underline" %></p>
                <p class="text-xs text-gray-500">Admin</p>
              </div>
            </div>
            <% if @is_admin && admin_actor != current_actor %>
              <div class="flex items-center gap-2">
                <%= form_with url: group_membership_path(@group, admin_actor), method: :patch, class: "flex items-center gap-1" do |f| %>
                  <%= f.hidden_field :from_role, value: "admin" %>
                  <%= f.select :to_role, [["Admin", "admin"], ["Moderator", "moderator"], ["Member", "member"]], { selected: "admin" }, { class: "text-xs border border-gray-300 rounded px-2 py-1" } %>
                  <%= f.submit "Save", class: "text-xs bg-blue-600 text-white px-2 py-1 rounded hover:bg-blue-700 cursor-pointer" %>
                <% end %>
                <%= button_to "Remove", group_membership_path(@group, admin_actor, role: "admin"), method: :delete, data: { turbo_confirm: "Remove #{admin_actor.name}?" }, class: "text-xs text-red-500 hover:text-red-700" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @moderators.any? %>
    <div class="mb-6">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Moderators (<%= @moderators.count %>)</h3>
      <div class="space-y-2">
        <% @moderators.each do |mod_actor| %>
          <div class="flex items-center justify-between bg-white border border-gray-100 rounded-lg px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-sm font-bold"><%= mod_actor.name[0].upcase %></div>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= link_to mod_actor.name, actor_path(mod_actor), class: "hover:underline" %></p>
                <p class="text-xs text-gray-500">Moderator</p>
              </div>
            </div>
            <% if @is_admin %>
              <div class="flex items-center gap-2">
                <%= form_with url: group_membership_path(@group, mod_actor), method: :patch, class: "flex items-center gap-1" do |f| %>
                  <%= f.hidden_field :from_role, value: "moderator" %>
                  <%= f.select :to_role, [["Admin", "admin"], ["Moderator", "moderator"], ["Member", "member"]], { selected: "moderator" }, { class: "text-xs border border-gray-300 rounded px-2 py-1" } %>
                  <%= f.submit "Save", class: "text-xs bg-blue-600 text-white px-2 py-1 rounded hover:bg-blue-700 cursor-pointer" %>
                <% end %>
                <%= button_to "Remove", group_membership_path(@group, mod_actor, role: "moderator"), method: :delete, data: { turbo_confirm: "Remove #{mod_actor.name}?" }, class: "text-xs text-red-500 hover:text-red-700" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div>
    <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Members (<%= @members.count %>)</h3>
    <% if @members.any? %>
      <div class="space-y-2">
        <% @members.each do |member_actor| %>
          <div class="flex items-center justify-between bg-white border border-gray-100 rounded-lg px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center text-gray-500 text-sm font-bold"><%= member_actor.name[0].upcase %></div>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= link_to member_actor.name, actor_path(member_actor), class: "hover:underline" %></p>
                <p class="text-xs text-gray-500">Member</p>
              </div>
            </div>
            <% if @is_admin %>
              <div class="flex items-center gap-2">
                <%= form_with url: group_membership_path(@group, member_actor), method: :patch, class: "flex items-center gap-1" do |f| %>
                  <%= f.hidden_field :from_role, value: "member" %>
                  <%= f.select :to_role, [["Admin", "admin"], ["Moderator", "moderator"], ["Member", "member"]], { selected: "member" }, { class: "text-xs border border-gray-300 rounded px-2 py-1" } %>
                  <%= f.submit "Save", class: "text-xs bg-blue-600 text-white px-2 py-1 rounded hover:bg-blue-700 cursor-pointer" %>
                <% end %>
                <%= button_to "Remove", group_membership_path(@group, member_actor, role: "member"), method: :delete, data: { turbo_confirm: "Remove #{member_actor.name}?" }, class: "text-xs text-red-500 hover:text-red-700" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400 py-4">No members yet.</p>
    <% end %>
  </div>
</div>
