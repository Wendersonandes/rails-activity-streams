<%= tag.div id: dom_id(activity), class: "bg-white rounded-xl border border-gray-200/80 p-5 shadow-sm hover:border-gray-300 transition-all duration-200" do %>
  <div class="flex items-start gap-4">
    <!-- Avatar -->
    <%
      is_group = activity.author.actorable_type == "Group"
      avatar_rounded = is_group ? "rounded-lg" : "rounded-full"
      avatar_bg = is_group ? "bg-emerald-50 text-emerald-600 border-emerald-100" : "bg-blue-50 text-blue-600 border-blue-100"
    %>
    <% if activity.author.avatar&.attached? %>
      <%= image_tag activity.author.avatar.variant(:thumb), class: "w-10 h-10 #{avatar_rounded} object-cover border border-gray-100 flex-shrink-0" %>
    <% else %>
      <div class="w-10 h-10 <%= avatar_rounded %> <%= avatar_bg %> flex items-center justify-center text-sm font-bold border flex-shrink-0">
        <%= activity.author.name.first.upcase %>
      </div>
    <% end %>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-gray-500 mb-2">
        <%= link_to activity.author.name, public_path_for(activity.author), class: "font-semibold text-gray-900 hover:text-blue-600 transition-colors" %>
        <span class="text-gray-300">&middot;</span>
        <span class="text-xs text-gray-400"><%= time_ago_in_words(activity.created_at) %> ago</span>
        <% if activity.represented_author? && activity.user_author %>
          <span class="text-[10px] font-medium bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded flex items-center gap-1">
            <i data-lucide="shield-check" class="w-3 h-3 text-gray-400"></i>
            <span>via <%= activity.user_author.email %></span>
          </span>
        <% end %>
      </div>

      <% activity.activity_objects.each do |ao| %>
        <div class="text-gray-800 space-y-1">
          <% if ao.title.present? %>
            <h3 class="font-semibold text-gray-900 text-base leading-tight"><%= ao.title %></h3>
          <% end %>
          <% if ao.description.present? %>
            <p class="text-sm leading-relaxed text-gray-600"><%= ao.description %></p>
          <% end %>
        </div>
      <% end %>

      <div class="flex items-center gap-5 mt-4 pt-3 border-t border-gray-100 text-sm text-gray-500">
        <% ao = activity.direct_object %>
        <% if ao %>
          <%= button_to activity_activity_actions_path(activity), method: :post, class: "flex items-center gap-1.5 text-gray-500 hover:text-blue-600 bg-transparent border-0 cursor-pointer p-0 transition-colors font-medium" do %>
            <i data-lucide="thumbs-up" class="w-4 h-4"></i>
            <span><%= ao.like_count %></span>
          <% end %>
          <div class="flex items-center gap-1.5 text-gray-500">
            <i data-lucide="message-square" class="w-4 h-4"></i>
            <span><%= ao.comment_count %></span>
          </div>
        <% end %>
        <% if activity.parent.present? %>
          <div class="flex items-center gap-1 text-xs text-gray-400 ml-auto">
            <i data-lucide="corner-down-right" class="w-3.5 h-3.5"></i>
            <span>in reply to <%= link_to activity.parent.author.name, activity_path(activity.parent), class: "font-medium text-gray-600 hover:text-blue-600 hover:underline" %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
