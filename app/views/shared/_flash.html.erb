<% if notice %>
  <div class="flex items-center gap-2.5 bg-green-50 border border-green-200/60 text-green-800 px-4 py-3 rounded-lg text-sm font-medium mb-5 shadow-sm" role="alert">
    <i data-lucide="check-circle-2" class="w-4 h-4 text-green-600 flex-shrink-0"></i>
    <span><%= notice %></span>
  </div>
<% end %>
<% if alert %>
  <div class="flex items-center gap-2.5 bg-red-50 border border-red-200/60 text-red-800 px-4 py-3 rounded-lg text-sm font-medium mb-5 shadow-sm" role="alert">
    <i data-lucide="alert-circle" class="w-4 h-4 text-red-600 flex-shrink-0"></i>
    <span><%= alert %></span>
  </div>
<% end %>
