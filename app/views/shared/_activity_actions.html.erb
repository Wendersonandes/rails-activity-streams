<% ao = activity.direct_object %>
<% if ao %>
  <div class="flex-1 flex items-center justify-between text-sm text-gray-500" id="<%= dom_id(activity, :actions) %>">
    <div class="flex items-center gap-5">
      <!-- Like Action -->
      <% if current_actor %>
        <% like = (ao.like_count > 0) ? Like.find(current_actor, activity) : nil %>
        <% if like %>
          <%= button_to activity_like_path(activity, like.id), method: :delete, class: "flex items-center gap-1.5 text-red-500 hover:text-red-650 bg-transparent border-0 cursor-pointer p-0 transition-colors font-medium" do %>
            <i data-lucide="heart" class="w-4 h-4 fill-current text-red-500"></i>
            <span><%= ao.like_count %></span>
          <% end %>
        <% else %>
          <%= button_to activity_likes_path(activity), method: :post, class: "flex items-center gap-1.5 text-gray-500 hover:text-red-500 bg-transparent border-0 cursor-pointer p-0 transition-colors font-medium" do %>
            <i data-lucide="heart" class="w-4 h-4"></i>
            <span><%= ao.like_count %></span>
          <% end %>
        <% end %>
      <% else %>
        <div class="flex items-center gap-1.5 text-gray-400 font-medium">
          <i data-lucide="heart" class="w-4 h-4"></i>
          <span><%= ao.like_count %></span>
        </div>
      <% end %>

      <!-- Follow Action -->
      <% if current_actor %>
        <% action = (ao.follower_count > 0) ? ao.received_actions.detect { |a| a.actor_id == current_actor.id && a.follow } : nil %>
        <% if action %>
          <%= button_to activity_activity_action_path(activity, action), method: :delete, class: "flex items-center gap-1.5 text-blue-650 hover:text-blue-750 bg-transparent border-0 cursor-pointer p-0 transition-colors font-medium" do %>
            <i data-lucide="bell" class="w-4 h-4 fill-current"></i>
            <span><%= ao.follower_count %></span>
          <% end %>
        <% else %>
          <%= button_to activity_activity_actions_path(activity), method: :post, class: "flex items-center gap-1.5 text-gray-500 hover:text-blue-650 bg-transparent border-0 cursor-pointer p-0 transition-colors font-medium" do %>
            <i data-lucide="bell" class="w-4 h-4"></i>
            <span><%= ao.follower_count %></span>
          <% end %>
        <% end %>
      <% else %>
        <div class="flex items-center gap-1.5 text-gray-400 font-medium">
          <i data-lucide="bell" class="w-4 h-4"></i>
          <span><%= ao.follower_count %></span>
        </div>
      <% end %>

      <%= link_to activity_path(activity), data: { turbo_stream: true }, class: "flex items-center gap-1.5 text-gray-500 hover:text-blue-600 transition-colors font-medium" do %>
        <i data-lucide="message-square" class="w-4 h-4"></i>
        <span><%= ao.comment_count %></span>
      <% end %>
    </div>

    <% if current_actor && activity.author_id == current_actor.id %>
      <div class="flex items-center">
        <%= button_to activity_path(activity), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this post?" }, class: "flex items-center gap-1.5 text-gray-400 hover:text-red-650 bg-transparent border-0 cursor-pointer p-0 transition-all font-medium" do %>
          <i data-lucide="trash-2" class="w-4 h-4"></i>
          <span>Trash</span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
