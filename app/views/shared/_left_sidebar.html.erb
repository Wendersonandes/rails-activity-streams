<% if current_actor %>
  <div class="space-y-6 sticky top-20">
    <!-- Mini Profile Card -->
    <div class="bg-white rounded-xl border border-gray-200/80 p-5 shadow-sm text-center">
      <div class="w-14 h-14 mx-auto rounded-full bg-blue-50 flex items-center justify-center text-blue-600 text-xl font-bold border border-blue-100 overflow-hidden mb-3">
        <% if current_actor.avatar.attached? %>
          <%= image_tag current_actor.avatar.variant(:thumb), class: "w-full h-full rounded-full object-cover" %>
        <% else %>
          <span><%= current_actor.name.first.upcase %></span>
        <% end %>
      </div>
      
      <h2 class="font-bold text-gray-900 text-sm truncate">
        <%= link_to current_actor.name, public_path_for(current_actor), class: "hover:text-blue-600 transition-colors" %>
      </h2>
      <p class="text-xs text-gray-400 font-medium capitalize mt-0.5">
        <%= current_actor.actorable_type.downcase %>
      </p>

      <div class="grid grid-cols-2 gap-2 mt-4 pt-4 border-t border-gray-100 text-center">
        <div>
          <span class="block text-sm font-bold text-gray-900"><%= current_actor.authored_activities.posts.count %></span>
          <span class="text-[10px] text-gray-400 font-medium">Posts</span>
        </div>
        <div>
          <span class="block text-sm font-bold text-gray-900"><%= current_actor.sent_active_contact_ids.size %></span>
          <span class="text-[10px] text-gray-400 font-medium">Connections</span>
        </div>
      </div>
    </div>

    <!-- Navigation List -->
    <div class="bg-white rounded-xl border border-gray-200/80 p-3 shadow-sm space-y-1">
      <% is_home = controller_name == 'activities' && action_name == 'index' %>
      <% is_contacts = controller_name == 'contacts' %>
      <% is_groups = (controller_name == 'groups' && action_name == 'index') || (controller_name == 'groups' && action_name == 'new') %>
      
      <%= link_to activities_path, class: "flex items-center gap-2.5 px-3 py-2 text-sm font-semibold rounded-lg transition-colors #{is_home ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50'}" do %>
        <i data-lucide="home" class="w-4 h-4 <%= is_home ? 'text-blue-600' : 'text-gray-450' %>"></i>
        <span>Home</span>
      <% end %>

      <%= link_to contacts_path, class: "flex items-center gap-2.5 px-3 py-2 text-sm font-semibold rounded-lg transition-colors #{is_contacts ? 'bg-blue-50 text-blue-600' : 'text-gray-600 hover:bg-gray-50'}" do %>
        <i data-lucide="users" class="w-4 h-4 <%= is_contacts ? 'text-blue-600' : 'text-gray-450' %>"></i>
        <span>Contacts</span>
      <% end %>

      <%= link_to groups_path, class: "flex items-center gap-2.5 px-3 py-2 text-sm font-semibold rounded-lg transition-colors #{is_groups ? 'bg-blue-50 text-blue-600' : 'text-gray-650 hover:bg-gray-50'}" do %>
        <i data-lucide="layers" class="w-4 h-4 <%= is_groups ? 'text-blue-600' : 'text-gray-450' %>"></i>
        <span>Groups</span>
      <% end %>
    </div>
  </div>
<% end %>
