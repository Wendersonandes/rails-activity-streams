<nav class="bg-white/90 backdrop-blur-md border-b border-gray-200/80 fixed top-0 left-0 right-0 z-50" data-controller="mobile-menu" aria-label="Global Navigation">
  <% if current_actor %>
    <%= turbo_stream_from current_actor, :notifications %>
  <% end %>
  <div class="container mx-auto px-5 flex items-center justify-between h-14">
    <div class="flex items-center gap-8">
      <%= link_to root_path, class: "flex items-center gap-2 font-bold text-base text-gray-900 tracking-tight hover:opacity-90 transition-opacity" do %>
        <i data-lucide="activity" class="w-5 h-5 text-blue-600"></i>
        <span>SocialStream</span>
      <% end %>
      
      <% if current_actor %>
        <div class="hidden sm:flex items-center gap-5">
          <%= link_to activities_path, class: "flex items-center gap-1.5 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors" do %>
            <i data-lucide="home" class="w-4 h-4"></i>
            <span>Home</span>
          <% end %>
          <%= link_to contacts_path, class: "flex items-center gap-1.5 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors" do %>
            <i data-lucide="users" class="w-4 h-4"></i>
            <span>Contacts</span>
          <% end %>
          <%= link_to groups_path, class: "flex items-center gap-1.5 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors" do %>
            <i data-lucide="layers" class="w-4 h-4"></i>
            <span>Groups</span>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Desktop Menu -->
    <div class="hidden sm:flex items-center gap-5">
      <% if user_signed_in? %>
        <% if current_actor %>
          <%= link_to public_path_for(current_actor), class: "flex items-center gap-1.5 text-sm font-semibold text-gray-700 hover:text-blue-600 transition-colors" do %>
            <div class="w-6 h-6 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 text-xs font-bold border border-blue-100">
              <%= current_actor.name.first.upcase %>
            </div>
            <span class="max-w-[120px] truncate"><%= current_actor.name %></span>
          <% end %>
        <% end %>
        <% if current_actor %>
          <%= link_to notifications_path, class: "relative p-1.5 text-gray-500 hover:text-blue-600 transition-colors flex items-center gap-1 mr-1", title: "Notifications" do %>
            <i data-lucide="bell" class="w-4.5 h-4.5"></i>
            <%= render "shared/nav_notification_badge" %>
          <% end %>
        <% end %>
        <%= link_to account_path, class: "flex items-center gap-1 text-sm text-gray-500 hover:text-gray-900 transition-colors" do %>
          <i data-lucide="settings" class="w-4 h-4"></i>
          <span>Account</span>
        <% end %>
        <%= button_to destroy_user_session_path, method: :delete, class: "flex items-center gap-1 text-sm text-gray-500 hover:text-red-600 bg-transparent border-0 cursor-pointer transition-colors p-0 font-medium" do %>
          <i data-lucide="log-out" class="w-4 h-4"></i>
          <span>Sign out</span>
        <% end %>
      <% else %>
        <%= link_to new_user_session_path, class: "flex items-center gap-1 text-sm font-medium text-gray-600 hover:text-blue-600 transition-colors" do %>
          <i data-lucide="log-in" class="w-4 h-4"></i>
          <span>Sign in</span>
        <% end %>
        <%= link_to new_user_registration_path, class: "flex items-center gap-1.5 text-sm bg-blue-600 hover:bg-blue-700 text-white px-3.5 py-1.5 rounded-lg font-medium shadow-sm hover:shadow transition-all duration-150" do %>
          <i data-lucide="user-plus" class="w-4 h-4"></i>
          <span>Sign up</span>
        <% end %>
      <% end %>
    </div>

    <!-- Mobile Menu Toggle Button -->
    <button type="button"
            data-action="click->mobile-menu#toggle"
            class="sm:hidden flex items-center justify-center w-9 h-9 rounded-lg hover:bg-gray-100 text-gray-650 cursor-pointer transition-colors"
            aria-label="Toggle navigation menu">
      <i data-lucide="menu" class="w-5 h-5"></i>
    </button>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div data-mobile-menu-target="menu" class="hidden sm:hidden bg-white border-t border-gray-250/30 px-5 py-3 space-y-2.5 shadow-md">
    <% if current_actor %>
      <%= link_to activities_path, class: "flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-blue-650 py-1 transition-colors" do %>
        <i data-lucide="home" class="w-4 h-4"></i>
        <span>Home</span>
      <% end %>
      <%= link_to contacts_path, class: "flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-blue-650 py-1 transition-colors" do %>
        <i data-lucide="users" class="w-4 h-4"></i>
        <span>Contacts</span>
      <% end %>
      <%= link_to groups_path, class: "flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-blue-650 py-1 transition-colors" do %>
          <i data-lucide="layers" class="w-4 h-4"></i>
          <span>Groups</span>
        <% end %>
      <%= link_to notifications_path, class: "flex items-center justify-between text-sm font-medium text-gray-700 hover:text-blue-650 py-1 transition-colors" do %>
        <div class="flex items-center gap-2">
          <i data-lucide="bell" class="w-4 h-4"></i>
          <span>Notifications</span>
        </div>
        <% unread_count = current_actor.notifications.unread.count %>
        <% if unread_count > 0 %>
          <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full">
            <%= unread_count %>
          </span>
        <% end %>
      <% end %>
      <hr class="border-gray-100">
    <% end %>
    
    <% if user_signed_in? %>
      <% if current_actor %>
        <%= link_to public_path_for(current_actor), class: "flex items-center gap-2 text-sm font-semibold text-gray-800 hover:text-blue-650 py-1 transition-colors" do %>
          <div class="w-6 h-6 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 text-xs font-bold border border-blue-100">
            <%= current_actor.name.first.upcase %>
          </div>
          <span><%= current_actor.name %></span>
        <% end %>
      <% end %>
      <%= link_to account_path, class: "flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 py-1 transition-colors" do %>
        <i data-lucide="settings" class="w-4 h-4"></i>
        <span>Account Settings</span>
      <% end %>
      <%= button_to destroy_user_session_path, method: :delete, class: "flex items-center gap-2 w-full text-left text-sm text-gray-600 hover:text-red-600 bg-transparent border-0 cursor-pointer py-1 transition-colors font-medium" do %>
        <i data-lucide="log-out" class="w-4 h-4"></i>
        <span>Sign out</span>
      <% end %>
    <% else %>
      <%= link_to new_user_session_path, class: "flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-blue-650 py-1 transition-colors" do %>
        <i data-lucide="log-in" class="w-4 h-4"></i>
        <span>Sign in</span>
      <% end %>
      <%= link_to new_user_registration_path, class: "flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-750 py-1 transition-colors" do %>
        <i data-lucide="user-plus" class="w-4 h-4"></i>
        <span>Sign up</span>
      <% end %>
    <% end %>
  </div>
</nav>
