<%# Update connection button on the profile page %>
<%= turbo_stream.replace dom_id(@other, :connection) do %>
  <%= render "shared/connection_button", actor: @other %>
<% end %>

<%# Remove suggestion from sidebar when connecting from the feed %>
<%= turbo_stream.remove dom_id(@other, :suggestion) %>

<%# Dispatch contact:changed event %>
<%= turbo_stream.append "body" do %>
  <div data-controller="event-dispatcher" data-event-dispatcher-name-value="contact:changed"></div>
<% end %>
